<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Couleurs de marque (mises à jour par EntrepriseBrandingService) -->
    <Color x:Key="BrandPrimaryColor">#FF1E3A5F</Color>
    <Color x:Key="BrandPrimaryDarkColor">#FF152238</Color>
    <Color x:Key="BrandPrimaryLightColor">#FF2D5A8A</Color>
    <Color x:Key="BrandSecondaryColor">#FF00A6B8</Color>

    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimaryColor}"/>
    <SolidColorBrush x:Key="BrandPrimaryDarkBrush" Color="{StaticResource BrandPrimaryDarkColor}"/>
    <SolidColorBrush x:Key="BrandSecondaryBrush" Color="{StaticResource BrandSecondaryColor}"/>
    <SolidColorBrush x:Key="BrandOnPrimaryBrush" Color="White"/>

    <!-- Barre latérale principale -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#FF152238"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#FF243652"/>
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="{StaticResource BrandPrimaryColor}"/>
    <SolidColorBrush x:Key="SidebarAccentBrush" Color="{StaticResource BrandSecondaryColor}"/>
    <SolidColorBrush x:Key="SidebarMutedBrush" Color="#FF8BA3C4"/>

    <!-- Boutons Material Design aux couleurs entreprise -->
    <Style x:Key="BrandRaisedButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Background" Value="{DynamicResource BrandPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrandPrimaryBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource BrandOnPrimaryBrush}"/>
    </Style>

    <Style x:Key="BrandRaisedSecondaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Background" Value="{DynamicResource BrandSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrandSecondaryBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource BrandOnPrimaryBrush}"/>
    </Style>

    <Style x:Key="BrandHeaderText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource BrandPrimaryBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="BrandHeaderBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrandPrimaryBrush}"/>
        <Setter Property="Padding" Value="20,18"/>
    </Style>

</ResourceDictionary>
