<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <!-- Garantit la restauration des packs runtime win-x64 (publish self-contained fiable, CI / clean) -->
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- Point d'entrÃ©e Program.cs : CWD = dossier exe avant WPF (pas SetDllDirectory : casse le chargement CLR) -->
    <StartupObject>MelodyPaieRDC.Program</StartupObject>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>MelodyPaieRDC</RootNamespace>
    <AssemblyName>MelodyPaieRDC</AssemblyName>
    <Company>Impact Entreprises</Company>
    <Product>Melody Paie RDC</Product>
    <Version>1.0.3</Version>
    <AssemblyVersion>1.0.3.0</AssemblyVersion>
    <FileVersion>1.0.3.0</FileVersion>
    <ApplicationIcon>Assets\Icon_MelodyPaie_Installer.ico</ApplicationIcon>
    <NuGetAudit>false</NuGetAudit>
  </PropertyGroup>

  <!-- Archive : fichiers conservÃ©s hors build (voir _archive/README.md) -->
  <ItemGroup>
    <Compile Remove="_archive\**\*" />
    <EmbeddedResource Remove="_archive\**\*" />
    <Page Remove="_archive\**\*" />
    <None Include="_archive\**\*" />
    <Compile Remove="tools\**\*" />
    <None Include="tools\**\*" />
  </ItemGroup>

  <!-- Projet console .NET Framework sÃ©parÃ© : ne pas compiler ses sources dans MelodyPaieRDC -->
  <ItemGroup>
    <Compile Remove="ZktecoPullWorker\**\*" />
    <None Include="ZktecoPullWorker\**\*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.102.2" />
    <PackageReference Include="DocumentFormat.OpenXml" Version="2.20.0" />
    <PackageReference Include="MaterialDesignThemes" Version="5.0.0" />
    <PackageReference Include="QuestPDF" Version="2024.3.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="8.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.10">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <!--
    ZktecoPullWorker est compilÃ© ici sans ProjectReference : une rÃ©fÃ©rence de projet vers un autre exÃ©cutable
    empÃªche le publish self-contained (NETSDK1150). La copie des fichiers reste dans les cibles ci-dessous.
  -->
  <Target Name="BuildZktecoPullWorker" BeforeTargets="BeforeBuild" Condition="'$(DesignTimeBuild)' != 'true'">
    <MSBuild Projects="$(MSBuildProjectDirectory)\ZktecoPullWorker\ZktecoPullWorker.csproj" Targets="Restore;Build" Properties="Configuration=$(Configuration)" />
  </Target>

  <!-- MSBuildProjectDirectory n'a pas de \ final : sans sÃ©parateur, le chemin devient ...\MelodyPaieRDCZktecoPullWorker et la copie ne s'exÃ©cute jamais. -->
  <!--
    Ne jamais copier les DLL net48 du worker Ã  la racine : elles Ã©crasent System.Memory.dll etc. du runtime .NET 8
    (TypeInitializationException sur System.Windows.Application). DÃ©ploiement isolÃ© sous ZktecoPullWorker\.
  -->
  <Target Name="CopyZktecoPullWorker" AfterTargets="CopyFilesToOutputDirectory">
    <PropertyGroup>
      <_ZkWorkerBin>$(MSBuildProjectDirectory)\ZktecoPullWorker\bin\$(Configuration)\net48\</_ZkWorkerBin>
      <_ZkWorkerDest>$(OutputPath)ZktecoPullWorker\</_ZkWorkerDest>
    </PropertyGroup>
    <MakeDir Directories="$(_ZkWorkerDest)" Condition="Exists('$(_ZkWorkerBin)ZktecoPullWorker.exe')" />
    <ItemGroup>
      <_ZkWorkerFiles Include="$(_ZkWorkerBin)*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_ZkWorkerFiles)" DestinationFolder="$(_ZkWorkerDest)" SkipUnchangedFiles="true" Condition="Exists('$(_ZkWorkerBin)ZktecoPullWorker.exe')" />
  </Target>

  <Target Name="CopyZktecoPullWorkerPublish" AfterTargets="Publish">
    <PropertyGroup>
      <_ZkWorkerBin>$(MSBuildProjectDirectory)\ZktecoPullWorker\bin\$(Configuration)\net48\</_ZkWorkerBin>
      <_ZkWorkerPublishDest>$(PublishDir)ZktecoPullWorker\</_ZkWorkerPublishDest>
    </PropertyGroup>
    <MakeDir Directories="$(_ZkWorkerPublishDest)" Condition="'$(PublishDir)' != '' And Exists('$(_ZkWorkerBin)ZktecoPullWorker.exe')" />
    <ItemGroup>
      <_ZkWorkerPublish Include="$(_ZkWorkerBin)*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_ZkWorkerPublish)" DestinationFolder="$(_ZkWorkerPublishDest)" SkipUnchangedFiles="true" Condition="'$(PublishDir)' != '' And Exists('$(_ZkWorkerBin)ZktecoPullWorker.exe')" />
  </Target>

  <!-- Ne pas copier PaieRDC.db depuis le projet : la base est crÃ©Ã©e au dÃ©marrage dans bin/.../Data/ -->
  <!-- <None Update="Data\PaieRDC.db"><CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory></None> -->

  <ItemGroup>
    <None Include="Forms\Defaults\**\*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Guides\**\*.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <!-- CopiÃ© Ã  cÃ´tÃ© de l'exe pour raccourcis (IconFilename Inno Setup) -->
    <!-- Link = copie Ã  la racine publish (pas sous Assets\) pour raccourcis Inno : IconFilename "{app}\Icon_MelodyPaie_Installer.ico" -->
    <None Include="Assets\Icon_MelodyPaie_Installer.ico">
      <Link>Icon_MelodyPaie_Installer.ico</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\Icon_MelodyPaie.png" />
    <Resource Include="Assets\Icon_MelodyPaie_Installer.png" />
    <!-- .ico installateur : pas en Resource (sinon pas copiÃ© Ã  cÃ´tÃ© de l'exe pour Inno IconFilename) ; voir ItemGroup None ci-dessus -->
    <Resource Include="Assets\Splash_Screen-67874262-217e-4c76-ab25-907a642e34d5.png" />
  </ItemGroup>

</Project>



