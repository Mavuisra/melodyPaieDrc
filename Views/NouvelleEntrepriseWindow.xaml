<Window x:Class="MelodyPaieRDC.Views.NouvelleEntrepriseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Nouvelle entreprise"
        Height="280" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Nouvelle entreprise" FontSize="18" FontWeight="SemiBold" Foreground="#1E3A5F"/>
            <TextBlock Text="Crée un espace client séparé (employés, paie, paramètres). L'assistant de configuration s'ouvrira ensuite."
                       TextWrapping="Wrap" Margin="0,8,0,0" Foreground="#546E7A" FontSize="13"/>
        </StackPanel>
        <TextBox x:Name="TxtRaisonSociale" Grid.Row="1"
                 materialDesign:HintAssist.Hint="Raison sociale *"
                 FontSize="14" VerticalAlignment="Top" Margin="0,4,0,0"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annuler" Click="Annuler_Click" Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Padding="16,8"/>
            <Button Content="Créer et configurer" Click="Creer_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1E3A5F" BorderBrush="#1E3A5F" Padding="16,8"/>
        </StackPanel>
    </Grid>
</Window>
