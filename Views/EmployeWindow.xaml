<Window x:Class="MelodyPaieRDC.Views.EmployeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding TitreFenetre}" Height="640" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F2F5"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource BrandHeaderBorder}">
            <StackPanel>
                <TextBlock Text="{Binding TitreFormulaire}" FontSize="17" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Fiche RH — champs obligatoires marqués *" FontSize="11" Foreground="#B0BEC5" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="16,12,16,0" Background="White" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Border Background="#FFF3E0" CornerRadius="8" Padding="12,8" Margin="12,12,12,0"
                        BorderBrush="#FFE0B2" BorderThickness="1"
                        Visibility="{Binding FormulaireLectureSeule, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="EyeOutline" Width="18" Height="18" Foreground="#E65100" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Consultation seule — votre compte ne peut pas modifier les fiches employés."
                                   TextWrapping="Wrap" FontSize="12" Foreground="#E65100" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Margin="12,8,12,12" VerticalScrollBarVisibility="Auto"
                              Padding="0,8,0,0"
                              IsEnabled="{Binding PeutEnregistrer}">
                    <StackPanel>
                        <TextBlock Text="Matricule *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.Matricule, UpdateSourceTrigger=PropertyChanged}" MaxLength="50" Margin="0,0,0,10"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <TextBlock Text="ID interne Melody" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding IdInterneText, UpdateSourceTrigger=PropertyChanged}" MaxLength="10" Margin="0,0,0,4"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBlock Text="Si l'ID existe déjà, l'application inter-échange automatiquement les IDs internes des deux employés (sans changer les matricules)."
                                   FontSize="11" Foreground="#78909C" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Text="ID utilisateur terminal (ZKTeco)" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.ZkUserId, UpdateSourceTrigger=PropertyChanged}" MaxLength="50" Margin="0,0,0,6"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBlock Text="IDs déjà utilisés :" FontSize="11" Foreground="#78909C"/>
                        <TextBlock Text="{Binding IdsUtilisateursExistants, Mode=OneWay}" TextWrapping="Wrap" FontSize="11" Foreground="#78909C" Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="Lire IDs terminal"
                                    Command="{Binding ChargerIdsTerminalCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="12,6" Margin="0,0,8,0"/>
                            <Button Content="Attribuer ID sélectionné"
                                    Command="{Binding AttribuerIdTerminalSelectionneCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="12,6"/>
                        </StackPanel>
                        <Border BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8" Padding="4" Margin="0,0,0,10" Background="#FAFCFE">
                            <ListBox ItemsSource="{Binding IdsTerminalDetectes}"
                                     SelectedItem="{Binding IdTerminalSelectionne, Mode=TwoWay}"
                                     Height="96" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding Id, Mode=OneWay}"/>
                                            <Run Text=" | "/>
                                            <Run Text="{Binding Nom, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <TextBlock Text="Employés déjà enregistrés (ID | Matricule | Nom)" FontSize="11" Foreground="#455A64" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Border BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,10" Background="#FAFCFE">
                            <ScrollViewer Height="80" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding EmployesEnregistresResume, Mode=OneWay}" TextWrapping="Wrap" FontSize="11" Foreground="#546E7A"/>
                            </ScrollViewer>
                        </Border>

                        <TextBlock Text="Nom *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.Nom, UpdateSourceTrigger=PropertyChanged}" MaxLength="100" Margin="0,0,0,8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <TextBlock Text="Postnom *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.Postnom, UpdateSourceTrigger=PropertyChanged}" MaxLength="100" Margin="0,0,0,8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <TextBlock Text="Prénom *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.Prenom, UpdateSourceTrigger=PropertyChanged}" MaxLength="100" Margin="0,0,0,8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <TextBlock Text="Sexe *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Sexes}" SelectedItem="{Binding Employe.Sexe, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,8" IsEditable="True" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                        <TextBlock Text="État civil *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding EtatsCivils}" SelectedItem="{Binding Employe.EtatCivil, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,8" IsEditable="True" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                        <TextBlock Text="Date de naissance *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding Employe.DateNaissance, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                        <TextBlock Text="Téléphone *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.Telephone, UpdateSourceTrigger=PropertyChanged}" MaxLength="30" Margin="0,0,0,8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <TextBlock Text="Numéro CNSS *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.NumCnss, UpdateSourceTrigger=PropertyChanged}" MaxLength="50" Margin="0,0,0,8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <TextBlock Text="Commune / territoire d'affectation (CNSS)" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.CommuneAffectation, UpdateSourceTrigger=PropertyChanged}" MaxLength="100" Margin="0,0,0,6"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBlock Text="Type travailleur CNSS" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <ComboBox SelectedValue="{Binding Employe.TypeTravailleurCnss, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag" Margin="0,0,0,8" Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem Content="1 — Travailleur" Tag="1"/>
                            <ComboBoxItem Content="2 — Assimilé" Tag="2"/>
                        </ComboBox>

                        <TextBlock Text="Coordonnées bancaires" FontWeight="SemiBold" Foreground="#37474F" Margin="0,4,0,8"/>
                        <TextBlock Text="Code banque" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.CodeBanque, UpdateSourceTrigger=PropertyChanged}" MaxLength="20" Margin="0,0,0,6"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBlock Text="Banque" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.LibelleBanque, UpdateSourceTrigger=PropertyChanged}" MaxLength="100" Margin="0,0,0,6"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBlock Text="N° compte" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.NumeroCompteBancaire, UpdateSourceTrigger=PropertyChanged}" MaxLength="50" Margin="0,0,0,6"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBlock Text="Titulaire du compte" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.TitulaireCompteBancaire, UpdateSourceTrigger=PropertyChanged}" MaxLength="150" Margin="0,0,0,6"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBlock Text="Devise compte (USD / CDF)" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.DeviseCompteBancaire, UpdateSourceTrigger=PropertyChanged}" MaxLength="10" Margin="0,0,0,8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <TextBlock Text="Adresse *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Employe.Adresse, UpdateSourceTrigger=PropertyChanged}" MaxLength="255"
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="56" VerticalContentAlignment="Top" Margin="0,0,0,8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <TextBlock Text="Département *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Departements}"
                                  DisplayMemberPath="NomDepartement"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding Employe.DepartementId, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,8"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Fermer" Command="{Binding AnnulerCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8" Padding="20,8" Margin="0,0,10,0" IsCancel="True"/>
                <Button Content="Enregistrer" Command="{Binding EnregistrerCommand}"
                        Style="{StaticResource BrandRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8" Padding="20,8" IsDefault="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
