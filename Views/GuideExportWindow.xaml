<Window x:Class="MelodyPaieRDC.Views.GuideExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Guide"
        Height="520" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnOuvrirPortail" Content="Ouvrir le portail CNSS" Click="OuvrirPortail_Click" Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Visibility="Collapsed"/>
            <Button Content="Fermer" IsCancel="True" Click="Fermer_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}" Padding="16,8"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="TxtGuide" IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0"
                     Background="Transparent" FontFamily="Consolas" FontSize="12"/>
        </ScrollViewer>
    </DockPanel>
</Window>
