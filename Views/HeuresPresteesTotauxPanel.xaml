<UserControl x:Class="MelodyPaieRDC.Views.HeuresPresteesTotauxPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:MelodyPaieRDC.ViewModels"
             xmlns:models="clr-namespace:MelodyPaieRDC.Models"
             Background="Transparent"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
             FontFamily="{materialDesign:MaterialDesignFont}">
    <UserControl.Resources>
        <!-- Intensité des heures (tons cyan / bleu vifs) -->
        <SolidColorBrush x:Key="CalN0" Color="#F0FDFA"/>
        <SolidColorBrush x:Key="CalN1" Color="#CCFBF1"/>
        <SolidColorBrush x:Key="CalN2" Color="#5EEAD4"/>
        <SolidColorBrush x:Key="CalN3" Color="#14B8A6"/>

        <Style x:Key="CalDayButton" TargetType="Button">
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="{StaticResource CalN0}"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="materialDesign:RippleAssist.Feedback" Value="#66214B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <materialDesign:Ripple Content="{TemplateBinding Content}"
                                                   Feedback="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(materialDesign:RippleAssist.Feedback)}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
        <Grid MaxWidth="1200">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" FontSize="12" Foreground="#546E7A" TextWrapping="Wrap" Margin="0,0,0,12">
                <Run Text="Somme des heures prestées par employé pour la période choisie. Calcul aligné sur le pointage journalier (LT depuis les horodatages, sinon valeurs enregistrées) — base pour le calcul de paie. Sélectionnez un employé pour explorer le calendrier mensuel et le détail par jour."/>
            </TextBlock>

            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="16,14" Margin="0,0,0,12"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.06"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="160"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Période de paie" FontWeight="SemiBold" FontSize="13" Foreground="#37474F"/>
                        <ComboBox ItemsSource="{Binding PeriodesPaie}"
                                  SelectedItem="{Binding PeriodeSelectionnee, Mode=TwoWay}"
                                  Margin="0,8,0,0"
                                  materialDesign:HintAssist.Hint="Mois / année"
                                  IsEditable="False">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding Mois}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding Annee}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBlock Text="Employé (calendrier)" FontWeight="SemiBold" FontSize="13" Foreground="#37474F"/>
                        <ComboBox ItemsSource="{Binding Employes}"
                                  SelectedItem="{Binding EmployeSelectionne, Mode=TwoWay}"
                                  Margin="0,8,0,0"
                                  materialDesign:HintAssist.Hint="Matricule / nom"
                                  IsEditable="False">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Employe}">
                                    <TextBlock>
                                        <Run Text="{Binding Matricule, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding Nom, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Postnom, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Prenom, Mode=OneWay}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <Button Grid.Row="0" Grid.Column="2"
                            Command="{Binding ActualiserTotauxCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Padding="12,8"
                            Margin="12,24,0,0"
                            VerticalAlignment="Top"
                            ToolTip="Recharger les périodes, employés et totaux">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Actualiser" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,12,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline" Width="18" Height="18" Foreground="#78909C" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Le calendrier affiche les heures calculées pour le mois affiché (indépendamment de la période de paie sélectionnée ci-dessus). Les créneaux horaires proviennent des pointages enregistrés." FontSize="11" Foreground="#78909C" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" MinHeight="240">
                <TextBlock Text="{Binding MessageVide}"
                           Foreground="#78909C"
                           FontSize="13"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="24">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AfficherTableau}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AfficherTableau}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Calendrier + détail (en premier — bien visible) -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AfficherCalendrierEmploye}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="280"/>
                            <ColumnDefinition Width="*" MinWidth="260"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="14" Padding="2,2,14,12" Margin="0,0,8,0"
                                BorderBrush="#99F6E4" BorderThickness="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#ECFEFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.12" Color="#14B8A6"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Command="{Binding MoisPrecedentCommand}"
                                            ToolTip="Mois précédent">
                                        <materialDesign:PackIcon Kind="ChevronLeft" Width="28" Height="28"/>
                                    </Button>
                                    <TextBlock Grid.Column="1" Text="{Binding MoisCalendrierLibelle, Mode=OneWay}"
                                               FontSize="19" FontWeight="Bold" Foreground="#0D9488"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Command="{Binding MoisSuivantCommand}"
                                            ToolTip="Mois suivant">
                                        <materialDesign:PackIcon Kind="ChevronRight" Width="28" Height="28"/>
                                    </Button>
                                </Grid>

                                <TextBlock Grid.Row="1" FontSize="12" Foreground="#64748B" Margin="0,0,0,8">
                                    <Run Text="Total du mois affiché : "/>
                                    <Run Text="{Binding TotalHeuresMoisAfficheLibelle, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource BrandPrimaryBrush}"/>
                                </TextBlock>

                                <!-- En-têtes jours (lundi → dimanche) -->
                                <UniformGrid Grid.Row="2" Rows="1" Columns="7" Margin="0,0,0,6">
                                    <TextBlock Text="lun" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                    <TextBlock Text="mar" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                    <TextBlock Text="mer" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                    <TextBlock Text="jeu" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                    <TextBlock Text="ven" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                    <TextBlock Text="sam" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                    <TextBlock Text="dim" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                </UniformGrid>

                                <ItemsControl Grid.Row="3" ItemsSource="{Binding CellulesCalendrier}" Focusable="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="6" Columns="7"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:CalendrierJourCellVm}">
                                            <Button Command="{Binding DataContext.SelectionnerJourCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding EstDansMoisVisible}">
                                                <Grid Width="100" MinHeight="52">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" HorizontalAlignment="Left" FontWeight="SemiBold" FontSize="14">
                                                        <TextBlock.Text>
                                                            <Binding Path="NumeroJour"/>
                                                        </TextBlock.Text>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#0F172A"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EstDansMoisVisible}" Value="False">
                                                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                                                        <Setter Property="Opacity" Value="0.55"/>
                                                                    </DataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding EstAujourdhui}" Value="True"/>
                                                                            <Condition Binding="{Binding EstDansMoisVisible}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Foreground" Value="#C026D3"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Grid.Row="1" Text="{Binding HeuresCourtLibelle}" FontSize="11" FontWeight="SemiBold"
                                                               HorizontalAlignment="Left" VerticalAlignment="Bottom" Foreground="#475569"
                                                               Margin="0,4,0,0"/>
                                                    <Ellipse Width="6" Height="6" Fill="#D946EF" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding EstAujourdhui}" Value="True"/>
                                                                            <Condition Binding="{Binding EstDansMoisVisible}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <Border Grid.Row="1"
                                                            Background="{Binding TypeJourBadgeCouleurFond}"
                                                            CornerRadius="8"
                                                            Padding="6,1"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Margin="0,4,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AfficherTypeJourBadge}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding TypeJourBadge}"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="{Binding TypeJourBadgeCouleurTexte}"/>
                                                    </Border>
                                                </Grid>
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource CalDayButton}">
                                                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EstSelectionne}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#DB2777"/>
                                                                <Setter Property="BorderThickness" Value="3"/>
                                                                <Setter Property="Foreground" Value="#831843"/>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#F472B6" BlurRadius="14" ShadowDepth="0" Opacity="0.85"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Setter Property="Background" Value="#FDF2F8"/>
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding EstWeekEnd}" Value="True"/>
                                                                    <Condition Binding="{Binding EstSelectionne}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Opacity" Value="0.88"/>
                                                            </MultiDataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding NiveauActivite}" Value="0"/>
                                                                    <Condition Binding="{Binding EstDansMoisVisible}" Value="True"/>
                                                                    <Condition Binding="{Binding EstSelectionne}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="{StaticResource CalN0}"/>
                                                            </MultiDataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding NiveauActivite}" Value="1"/>
                                                                    <Condition Binding="{Binding EstDansMoisVisible}" Value="True"/>
                                                                    <Condition Binding="{Binding EstSelectionne}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="{StaticResource CalN1}"/>
                                                            </MultiDataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding NiveauActivite}" Value="2"/>
                                                                    <Condition Binding="{Binding EstDansMoisVisible}" Value="True"/>
                                                                    <Condition Binding="{Binding EstSelectionne}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="{StaticResource CalN2}"/>
                                                            </MultiDataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding NiveauActivite}" Value="3"/>
                                                                    <Condition Binding="{Binding EstDansMoisVisible}" Value="True"/>
                                                                    <Condition Binding="{Binding EstSelectionne}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="{StaticResource CalN3}"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <!-- Détail jour sélectionné -->
                        <Border Grid.Column="1" x:Name="DetailJourCard" CornerRadius="14" Padding="16,14" Margin="8,0,0,0"
                                BorderBrush="#DDE8F2" BorderThickness="1"
                                Background="#F8FBFF"
                                MinHeight="200"
                                materialDesign:ElevationAssist.Elevation="Dp2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AfficherPanelDetail}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AfficherPanelDetail}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Journée sélectionnée" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding DetailJour.TitreDate}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrandPrimaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding DetailJour.SousTitreJour}" FontSize="12" Foreground="#64748B" Margin="0,4,0,12" TextWrapping="Wrap"/>

                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="10,8" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Type du jour (admin)" FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                                            <ComboBox ItemsSource="{Binding DetailJour.TypesJourDisponibles}"
                                                      SelectedItem="{Binding DetailJour.TypeJourSelectionne, Mode=TwoWay}"
                                                      Margin="0,6,10,0"
                                                      IsEditable="False"
                                                      materialDesign:HintAssist.Hint="Choisir le type"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{Binding EnregistrerTypeJourCommand}"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="8"
                                                Padding="12,8"
                                                VerticalAlignment="Bottom"
                                                Margin="8,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="CheckBold" Width="16" Height="16" Margin="0,0,6,0"/>
                                                <TextBlock Text="Valider type"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Heures prestées" FontSize="11" Foreground="#78909C"/>
                                        <TextBlock Text="{Binding DetailJour.HeuresLibelle}" FontSize="18" FontWeight="SemiBold" Foreground="#0F766E"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Mode de calcul" FontSize="11" Foreground="#78909C"/>
                                        <TextBlock Text="{Binding DetailJour.ModeCalcul}" FontSize="13" FontWeight="SemiBold" Foreground="#334155" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Moments de pointage" FontSize="12" FontWeight="Bold" Foreground="#0D9488" Margin="0,4,0,6"/>
                                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,10"
                                           Text="Lun–ven : édition selon le mode de pointage de l’entreprise (2, 3 ou 4 lectures). Les lectures supplémentaires restent listées ci‑dessous."/>

                                <!-- Lun–Ven -->
                                <StackPanel Margin="0,0,0,10">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DetailJour.AfficherGrilleJourOuvrable}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border CornerRadius="12" Padding="10,8" Margin="0,0,0,8" BorderThickness="2" BorderBrush="#14B8A6" Background="#F0FDFA">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Login" Width="22" Height="22" Foreground="#0D9488" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Entrée" FontWeight="Bold" FontSize="12" Foreground="#0F766E"/>
                                                <TextBox Text="{Binding DetailJour.EntreeHhMm, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="HH:mm (ex. 07:32)"
                                                         IsEnabled="{Binding DetailJour.PeutEditerMoments}" Margin="0,4,0,0" FontSize="15" FontWeight="SemiBold" Foreground="#0C4A6E"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border CornerRadius="12" Padding="10,8" Margin="0,0,0,8" BorderThickness="2" BorderBrush="#F59E0B" Background="#FFFBEB">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DetailJour.AfficherChampsPause}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="CoffeeOutline" Width="22" Height="22" Foreground="#D97706" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#B45309">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Début de pause"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DetailJour.EstLayoutTroisPointages}" Value="True">
                                                                    <Setter Property="Text" Value="Pause"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBox Text="{Binding DetailJour.DebutPauseHhMm, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="HH:mm"
                                                         IsEnabled="{Binding DetailJour.PeutEditerMoments}" Margin="0,4,0,0" FontSize="15" FontWeight="SemiBold" Foreground="#78350F"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border CornerRadius="12" Padding="10,8" Margin="0,0,0,8" BorderThickness="2" BorderBrush="#F97316" Background="#FFF7ED">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DetailJour.AfficherFinPause}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="PauseCircleOutline" Width="22" Height="22" Foreground="#EA580C" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Fin de pause" FontWeight="Bold" FontSize="12" Foreground="#C2410C"/>
                                                <TextBox Text="{Binding DetailJour.FinPauseHhMm, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="HH:mm"
                                                         IsEnabled="{Binding DetailJour.PeutEditerMoments}" Margin="0,4,0,0" FontSize="15" FontWeight="SemiBold" Foreground="#7C2D12"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border CornerRadius="12" Padding="10,8" BorderThickness="2" BorderBrush="#A855F7" Background="#FAF5FF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Logout" Width="22" Height="22" Foreground="#9333EA" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Sortie" FontWeight="Bold" FontSize="12" Foreground="#6B21A8"/>
                                                <TextBox Text="{Binding DetailJour.SortieHhMm, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="HH:mm"
                                                         IsEnabled="{Binding DetailJour.PeutEditerMoments}" Margin="0,4,0,0" FontSize="15" FontWeight="SemiBold" Foreground="#581C87"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- Samedi -->
                                <StackPanel Margin="0,0,0,10">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DetailJour.EstLayoutSamedi}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,8"
                                               Text="Samedi : première et dernière lecture pour le calcul LT ; lectures intermédiaires conservées ci‑dessous."/>
                                    <Border CornerRadius="12" Padding="10,8" Margin="0,0,0,8" BorderThickness="2" BorderBrush="#059669" Background="#ECFDF5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Login" Width="22" Height="22" Foreground="#059669" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Entrée" FontWeight="Bold" FontSize="12" Foreground="#047857"/>
                                                <TextBox Text="{Binding DetailJour.EntreeHhMm, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="HH:mm"
                                                         IsEnabled="{Binding DetailJour.PeutEditerMoments}" Margin="0,4,0,0" FontSize="15" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border CornerRadius="12" Padding="10,8" BorderThickness="2" BorderBrush="#4F46E5" Background="#EEF2FF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Logout" Width="22" Height="22" Foreground="#4F46E5" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Sortie" FontWeight="Bold" FontSize="12" Foreground="#4338CA"/>
                                                <TextBox Text="{Binding DetailJour.SortieHhMm, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="HH:mm"
                                                         IsEnabled="{Binding DetailJour.PeutEditerMoments}" Margin="0,4,0,0" FontSize="15" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- Dimanche / hors édition standard -->
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#94A3B8" FontStyle="Italic" Margin="0,0,0,8"
                                           Text="Édition par moment non disponible pour ce jour (week-end complet ou type de jour particulier).">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding DetailJour.AfficherGrilleJourOuvrable}" Value="False"/>
                                                        <Condition Binding="{Binding DetailJour.EstLayoutSamedi}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Pointages supplémentaires (lecture seule) -->
                                <TextBlock Text="Pointages supplémentaires" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,8,0,6">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DetailJour.AfficherPointagesSupplementaires}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding DetailJour.PointagesSupplementaires}" Margin="0,0,0,8">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DetailJour.AfficherPointagesSupplementaires}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFF1F2" CornerRadius="8" Padding="8,5" Margin="0,0,6,6" BorderBrush="#FDA4AF" BorderThickness="1">
                                                <TextBlock Text="{Binding}" FontWeight="Bold" FontSize="12" Foreground="#BE123C"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding DetailJour.MessageStatut}" TextWrapping="Wrap" Margin="0,4,0,6" FontSize="12" FontWeight="SemiBold" Foreground="#C026D3"/>

                                <Button Content="Enregistrer les horaires"
                                        Command="{Binding EnregistrerMomentsCommand}"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,4,0,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DetailJour.PeutEditerMoments}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Placeholder sans jour sélectionné -->
                        <Border Grid.Column="1" Margin="8,0,0,0" Padding="16" CornerRadius="14" BorderBrush="#E8EDF2" BorderThickness="1" Background="#FAFCFE"
                                MinHeight="120">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AfficherPanelDetail}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="CalendarClock" Width="40" Height="40" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                <TextBlock Text="Cliquez sur un jour du calendrier pour afficher le détail et les créneaux horaires." FontSize="13" Foreground="#94A3B8"
                                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Message si pas d’employé sélectionné -->
                    <Border Grid.Row="1" Background="#FAFCFE" CornerRadius="12" Padding="20" BorderBrush="#E8EDF2" BorderThickness="1" Margin="0,0,0,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AfficherCalendrierEmploye}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AfficherTableau}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountOutline" Width="22" Height="22" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Choisissez un employé ci-dessus pour afficher le calendrier interactif et les disponibilités par jour." FontSize="13" Foreground="#64748B" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Table bas : récap période OU pointages du jour sélectionné -->
                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="#0D9488" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="{Binding TitreTableauBas, Mode=OneWay}"/>

                        <!-- Récap tous employés (période) -->
                        <Border Background="White" CornerRadius="12" Padding="0"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.07"/>
                            </Border.Effect>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AfficherTableauRecapEmployesPeriode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DataGrid ItemsSource="{Binding Lignes}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      Background="Transparent"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F8FAFC"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#ECEFF1"
                                      RowHeight="36"
                                      BorderThickness="0"
                                      MaxHeight="420"
                                      VerticalAlignment="Top"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F0F4F8"/>
                                        <Setter Property="Foreground" Value="#37474F"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Matricule" Binding="{Binding Matricule}" Width="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Employé" Binding="{Binding NomComplet}" Width="*" MinWidth="160" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Département" Binding="{Binding Departement}" Width="140" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Total heures" Binding="{Binding TotalHeuresLibelle}" Width="130" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Pointages : jour sélectionné uniquement -->
                        <Border Background="White" CornerRadius="12" Padding="0"
                                BorderBrush="#99F6E4" BorderThickness="2" Margin="0,0,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.09" Color="#14B8A6"/>
                            </Border.Effect>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AfficherTableauPointagesJourSelectionne}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DataGrid ItemsSource="{Binding LignesPointagesJour}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      Background="#FAFFFE"
                                      RowHeight="44"
                                      BorderThickness="0"
                                      MaxHeight="420"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#CCFBF1">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#ECFEFF"/>
                                        <Setter Property="Foreground" Value="#0F766E"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Moment" Width="*" MinWidth="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="14" Padding="12,8" Margin="4,2" BorderThickness="2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                            <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MomentCle}" Value="Entree">
                                                                    <Setter Property="Background" Value="#CCFBF1"/>
                                                                    <Setter Property="BorderBrush" Value="#14B8A6"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MomentCle}" Value="PauseDebut">
                                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                                    <Setter Property="BorderBrush" Value="#F59E0B"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MomentCle}" Value="PauseFin">
                                                                    <Setter Property="Background" Value="#FFEDD5"/>
                                                                    <Setter Property="BorderBrush" Value="#F97316"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MomentCle}" Value="Sortie">
                                                                    <Setter Property="Background" Value="#EDE9FE"/>
                                                                    <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MomentCle}" Value="Extra">
                                                                    <Setter Property="Background" Value="#FCE7F3"/>
                                                                    <Setter Property="BorderBrush" Value="#EC4899"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MomentCle}" Value="Dimanche">
                                                                    <Setter Property="Background" Value="#E2E8F0"/>
                                                                    <Setter Property="BorderBrush" Value="#64748B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontWeight="Bold" FontSize="13" Text="{Binding MomentLibelle}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#334155"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding MomentCle}" Value="Entree">
                                                                        <Setter Property="Foreground" Value="#065F46"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MomentCle}" Value="PauseDebut">
                                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MomentCle}" Value="PauseFin">
                                                                        <Setter Property="Foreground" Value="#9A3412"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MomentCle}" Value="Sortie">
                                                                        <Setter Property="Foreground" Value="#5B21B6"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MomentCle}" Value="Extra">
                                                                        <Setter Property="Foreground" Value="#9D174D"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MomentCle}" Value="Dimanche">
                                                                        <Setter Property="Foreground" Value="#334155"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Heure pointée" Binding="{Binding HeureBruteHhMm}" Width="130" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="14"/>
                                                <Setter Property="Foreground" Value="#0F172A"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="8,4"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Retenue pour calcul LT" Binding="{Binding HeurePourCalculLtHhMm}" Width="170" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="FontSize" Value="14"/>
                                                <Setter Property="Foreground" Value="#047857"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="8,4"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="#64748B" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AfficherTableauPointagesJourSelectionne}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="Lun–ven : avant 7h30 → compté 7h30 ; après la fin officielle → plafonné à l’heure de fin. "/>
                            <Run Text="La colonne « Retenue pour calcul LT » reflète ces règles." FontWeight="SemiBold" Foreground="#0D9488"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Grid.Row="3" Background="#EEF4FA" CornerRadius="10" Padding="14,10" Margin="0,12,0,0"
                    BorderBrush="#DDE8F2" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Sigma" Width="22" Height="22" Foreground="{DynamicResource BrandPrimaryBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="#37474F">
                            <Run Text="Période : " FontWeight="SemiBold"/>
                            <Run Text="{Binding PériodeLibellé, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Grid.Column="1" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrandPrimaryBrush}" VerticalAlignment="Center">
                        <Run Text="Total général : "/>
                        <Run Text="{Binding TotalGeneralHeuresLibelle, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
            </Border>

            <Border Grid.Row="4" Margin="0,12,0,0" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <TabControl SelectedIndex="0">
                    <TabItem Header="Analyse heures &amp; jours">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,10">
                                <Border CornerRadius="10" Background="#ECFEFF" BorderBrush="#99F6E4" BorderThickness="1" Padding="10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Total période (heures)" FontSize="11" Foreground="#0F766E"/>
                                        <TextBlock Text="{Binding TotalGeneralHeuresLibelle, Mode=OneWay}" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="10" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" Padding="10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Total période (jours équiv.)" FontSize="11" Foreground="#4338CA"/>
                                        <TextBlock Text="{Binding TotalGeneralJoursEquivalentLibelle, Mode=OneWay}" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="10" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="Employé sélectionné (mois affiché)" FontSize="11" Foreground="#166534"/>
                                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="#0F172A">
                                            <Run Text="{Binding TotalHeuresMoisAfficheLibelle, Mode=OneWay}"/>
                                            <Run Text="  •  "/>
                                            <Run Text="{Binding TotalJoursMoisAfficheLibelle, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <TextBlock Grid.Row="1" Text="Lecture rapide : 1 jour équivalent = 8 heures (conversion d’affichage)." FontSize="11" Foreground="#64748B" Margin="2,0,0,8"/>

                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding Lignes}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      Background="Transparent"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F8FAFC"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#E2E8F0"
                                      RowHeight="38"
                                      BorderThickness="0"
                                      MaxHeight="280"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="Foreground" Value="#334155"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Matricule" Binding="{Binding Matricule}" Width="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Employé" Binding="{Binding NomComplet}" Width="*" MinWidth="180" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Département" Binding="{Binding Departement}" Width="150" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Heures" Binding="{Binding TotalHeuresLibelle, Mode=OneWay}" Width="120" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Jours équiv." Binding="{Binding TotalJoursEquivalentLibelle, Mode=OneWay}" Width="120" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Vue synthèse">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                                <Border CornerRadius="12" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" Padding="12" Margin="0,0,10,10" Width="250">
                                    <StackPanel>
                                        <TextBlock Text="Heures totales période" Foreground="#4338CA" FontSize="11"/>
                                        <TextBlock Text="{Binding TotalGeneralHeuresLibelle, Mode=OneWay}" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="12" Background="#ECFEFF" BorderBrush="#99F6E4" BorderThickness="1" Padding="12" Margin="0,0,10,10" Width="250">
                                    <StackPanel>
                                        <TextBlock Text="Jours équivalents période" Foreground="#0F766E" FontSize="11"/>
                                        <TextBlock Text="{Binding TotalGeneralJoursEquivalentLibelle, Mode=OneWay}" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="12" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" Padding="12" Margin="0,0,10,10" Width="320">
                                    <StackPanel>
                                        <TextBlock Text="Employé sélectionné (mois)" Foreground="#166534" FontSize="11"/>
                                        <TextBlock FontSize="22" FontWeight="Bold" Foreground="#111827">
                                            <Run Text="{Binding TotalHeuresMoisAfficheLibelle, Mode=OneWay}"/>
                                            <Run Text="  /  "/>
                                            <Run Text="{Binding TotalJoursMoisAfficheLibelle, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <TextBlock Grid.Row="1"
                                       Text="Onglet pensé pour une lecture manager : heures + jours sur un seul écran, visuel et rapide."
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="2,0,0,0"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
