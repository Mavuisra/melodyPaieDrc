<Window x:Class="MelodyPaieRDC.Views.EmployeHeuresMoisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Heures de travail — employé"
        Height="620"
        Width="980"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Window.Resources>
        <x:Array x:Key="TypesJour" Type="{x:Type sys:String}">
            <sys:String>Normal</sys:String>
            <sys:String>Congé de circonstance</sys:String>
            <sys:String>Maladie</sys:String>
            <sys:String>Préavis</sys:String>
        </x:Array>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="EmployeNomText" FontWeight="SemiBold" FontSize="16" Foreground="#1E293B"/>
                <TextBlock x:Name="EmployeMetaText" Margin="0,4,0,0" Foreground="#64748B" FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,12" Background="White" CornerRadius="12" Padding="12" BorderBrush="#E2E8F0" BorderThickness="1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="CalendarMonth" Width="18" Height="18" Foreground="#334155" Margin="0,0,8,0"/>
                    <TextBlock Text="Période :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="PeriodeCombo" Width="220" DisplayMemberPath="Libelle" SelectionChanged="PeriodeCombo_SelectionChanged"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Text="Total heures :" VerticalAlignment="Center" Foreground="#475569"/>
                    <TextBlock x:Name="TotalHeuresText" Margin="8,0,0,0" FontWeight="SemiBold" Foreground="#0F172A"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="HeuresDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E2E8F0"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC"
                      BorderThickness="0"
                      RowHeight="36">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding DateAffichage}" Width="110" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Jour" Binding="{Binding JourSemaine}" Width="140" IsReadOnly="True"/>
                    <DataGridTextColumn Header="1/0" Binding="{Binding JourCode}" Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Mode" Binding="{Binding ModeCalcul}" Width="110" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Heures" Binding="{Binding HeuresPrestees, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90"/>
                    <DataGridComboBoxColumn Header="Type jour"
                                            Width="*"
                                            ItemsSource="{StaticResource TypesJour}"
                                            SelectedItemBinding="{Binding TypeJour, UpdateSourceTrigger=PropertyChanged}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Enregistrer"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="Enregistrer_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"/>
            <Button Content="Fermer"
                    Width="120"
                    Click="Fermer_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"/>
        </StackPanel>
    </Grid>
</Window>
