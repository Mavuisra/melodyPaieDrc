<Window x:Class="MelodyPaieRDC.Views.UtilisateursWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Gestion des utilisateurs"
        Height="420" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Utilisateurs ayant accès à l'application. Rôles : Admin (tout + gestion users), Gestionnaire (tout sauf users), Lecture (consultation)."
                 TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.9" FontSize="12"/>
        <DataGrid x:Name="GridUtilisateurs" Grid.Row="1"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" Margin="0,0,0,12" Background="White"
                  SelectionMode="Single" SelectionChanged="GridUtilisateurs_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Identifiant" Binding="{Binding Login}" Width="120"/>
                <DataGridTextColumn Header="Nom complet" Binding="{Binding NomComplet}" Width="*"/>
                <DataGridTextColumn Header="Rôle" Binding="{Binding Role}" Width="100"/>
                <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Actif}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnAjouter" Content="Ajouter" Click="Ajouter_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6" Padding="16,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnModifier" Content="Modifier" Click="Modifier_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6" Padding="16,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnMotDePasse" Content="Changer mot de passe" Click="ChangerMotDePasse_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6" Padding="16,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnSupprimer" Content="Supprimer" Click="Supprimer_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6" Padding="16,8"/>
        </StackPanel>
    </Grid>
</Window>
