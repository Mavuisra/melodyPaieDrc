<UserControl x:Class="MelodyPaieRDC.Views.BulletinView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Background="White" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- En-tête entreprise / logo / période -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="Bulletin de paie" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Margin="0,2,0,0">
                        <Run Text="N° "/>
                        <Run Text="{Binding NumeroBulletin, TargetNullValue='-', FallbackValue='-'}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding Employe.Nom}" FontSize="14" Margin="0,6,0,0"/>
                    <TextBlock>
                        <Run Text="Matricule : "/>
                        <Run Text="{Binding Employe.Matricule}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Département : "/>
                        <Run Text="{Binding Employe.Departement.NomDepartement}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="Période" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    <TextBlock HorizontalAlignment="Right">
                        <Run Text="{Binding PeriodePaie.Mois}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding PeriodePaie.Annee}"/>
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Right">
                        <Run Text="Généré le : "/>
                        <Run Text="{Binding DateGeneration, StringFormat=dd/MM/yyyy}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- Résumé des montants -->
            <Grid Grid.Row="1" Margin="0,16,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Gains" FontWeight="SemiBold"/>
                    <TextBlock>
                        <Run Text="Imposables : "/>
                        <Run Text="{Binding TotalGainImposable, StringFormat=N2}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Non imposables : "/>
                        <Run Text="{Binding TotalGainNonImposable, StringFormat=N2}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="IPR" FontWeight="SemiBold"/>
                    <TextBlock>
                        <Run Text="Base IPR : "/>
                        <Run Text="{Binding BaseIpr, StringFormat=N2}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="IPR brut : "/>
                        <Run Text="{Binding MontantIprBrut, StringFormat=N2}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Réduction famille : "/>
                        <Run Text="{Binding ReductionFamille, StringFormat=N2}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="IPR net : "/>
                        <Run Text="{Binding MontantIprNet, StringFormat=N2}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Résultat" FontWeight="SemiBold"/>
                    <TextBlock>
                        <Run Text="CNSS ouvrier : "/>
                        <Run Text="{Binding CotisationCnssOuvrier, StringFormat=N2}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="INPP : "/>
                        <Run Text="{Binding CotisationInpp, StringFormat=N2}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Net à payer : "/>
                        <Run Text="{Binding NetAPayer, StringFormat=N2}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Net en devise locale : "/>
                        <Run Text="{Binding NetAPayerDeviseLocale, StringFormat=N2}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- Détails -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Details}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      Margin="0,0,0,8"
                      Background="White"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Libellé" Binding="{Binding Libelle}" Width="*"/>
                    <DataGridTextColumn Header="Base" Binding="{Binding BaseCalcul, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="Taux" Binding="{Binding Taux, StringFormat=N2}" Width="80"/>
                    <DataGridTextColumn Header="Gain" Binding="{Binding Gain, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="Retenue" Binding="{Binding Retenue, StringFormat=N2}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Pied de page -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Signature employeur" Margin="0,0,40,0"/>
                <TextBlock Text="Signature employé"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
