<Window x:Class="MelodyPaieRDC.Views.SaisiePaieMoisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:helpers="clr-namespace:MelodyPaieRDC.Helpers"
        Title="Saisie de la paie du mois"
        Height="520" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <helpers:StringToIntConverter x:Key="StringToIntConverter"/>
        <helpers:StringToDecimalConverter x:Key="StringToDecimalConverter"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Saisie de la paie du mois" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="Renseignez les jours prestés, les gains supplémentaires, les acomptes et les sanctions pour chaque employé. Les valeurs vides ne modifient pas le calcul automatique." FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"/>
            <TextBlock Text="Mode lecture seule — consultation uniquement." FontSize="12" Foreground="#E65100" FontWeight="SemiBold" Margin="0,8,0,0"
                       Visibility="{Binding FormulaireLectureSeule, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Lignes}"
                  IsReadOnly="{Binding FormulaireLectureSeule}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Matricule" Binding="{Binding Matricule}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding NomComplet}" Width="*"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Jours prestés"
                                    Width="80">
                    <DataGridTextColumn.Binding>
                        <Binding Path="JoursPrestes" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay"
                                 Converter="{StaticResource StringToIntConverter}"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Autres gains imposables"
                                    Width="130">
                    <DataGridTextColumn.Binding>
                        <Binding Path="AutresGainsImposables" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay"
                                 Converter="{StaticResource StringToDecimalConverter}"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Autres gains non imposables"
                                    Width="150">
                    <DataGridTextColumn.Binding>
                        <Binding Path="AutresGainsNonImposables" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay"
                                 Converter="{StaticResource StringToDecimalConverter}"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Autres retenues"
                                    Width="110">
                    <DataGridTextColumn.Binding>
                        <Binding Path="AutresRetenues" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay"
                                 Converter="{StaticResource StringToDecimalConverter}"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Acomptes sur salaire"
                                    Width="130">
                    <DataGridTextColumn.Binding>
                        <Binding Path="AcomptesSalaire" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay"
                                 Converter="{StaticResource StringToDecimalConverter}"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Sanctions disciplinaires"
                                    Width="150">
                    <DataGridTextColumn.Binding>
                        <Binding Path="SanctionsDisciplinaires" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay"
                                 Converter="{StaticResource StringToDecimalConverter}"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Commentaire" Binding="{Binding Commentaire, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Enregistrer"
                    Command="{Binding EnregistrerCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    Padding="16,8"/>
        </StackPanel>
    </Grid>
</Window>

