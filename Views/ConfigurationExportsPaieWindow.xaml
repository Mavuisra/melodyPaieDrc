<Window x:Class="MelodyPaieRDC.Views.ConfigurationExportsPaieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Exports et clôture paie"
        Height="620" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#F0F2F5"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Configuration des exports (CNSS, DGI, livre, virements)"
                   FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#607D8B" Margin="0,0,0,12"
                   Text="Colonnes, contrôles et règles modifiables sans recompiler. Les jetons Source (ex. Bulletin.NetAPayer) sont documentés dans l'aide intégrée des exports."/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Profil à éditer" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding ProfilsDisponibles}" SelectedItem="{Binding ProfilSelectionne, Mode=TwoWay}" Margin="0,0,0,16"/>
                <TextBlock Text="Clôture" FontWeight="SemiBold" Margin="0,8,0,6"/>
                <CheckBox Content="Bloquer si erreurs de contrôle" IsChecked="{Binding ExigerControlesSansErreur}" Margin="0,4"/>
                <CheckBox Content="Exports officiels : période clôturée" IsChecked="{Binding ExportsExigentCloture}" Margin="0,4"/>
                <CheckBox Content="Bloquer saisie paie si clôturée" IsChecked="{Binding BloquerSaisieSiCloturee}" Margin="0,4"/>
                <TextBlock Text="Profil virement par défaut" Margin="0,12,0,4" FontSize="11"/>
                <ComboBox ItemsSource="{Binding ProfilsVirement}" Text="{Binding CodeProfilVirementParDefaut, Mode=TwoWay}" IsEditable="True"/>
            </StackPanel>
            <TabControl Grid.Column="1">
                <TabItem Header="Colonnes export">
                    <DataGrid ItemsSource="{Binding Colonnes}" AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" Margin="4">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Actif, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                            <DataGridTextColumn Header="Ordre" Binding="{Binding Ordre, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                            <DataGridTextColumn Header="Libellé" Binding="{Binding Libelle, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding SourceDonnee}" Width="160" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Contrôles clôture">
                    <DataGrid ItemsSource="{Binding ControlesCloture}" AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" Margin="4">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Actif}" Width="50"/>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="140" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Libellé" Binding="{Binding Libelle, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridComboBoxColumn Header="Sévérité" SelectedItemBinding="{Binding Severite, UpdateSourceTrigger=PropertyChanged}" Width="100">
                                <DataGridComboBoxColumn.ItemsSource>
                                    <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                        <sys:String>Erreur</sys:String>
                                        <sys:String>Avertissement</sys:String>
                                    </x:Array>
                                </DataGridComboBoxColumn.ItemsSource>
                            </DataGridComboBoxColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Réinitialiser défauts" Command="{Binding ReinitialiserCommand}" Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Padding="14,8"/>
            <Button Content="Enregistrer" Command="{Binding EnregistrerCommand}"
                    Style="{StaticResource BrandRaisedButton}" Padding="20,10"/>
        </StackPanel>
    </Grid>
</Window>
