<Window x:Class="MelodyPaieRDC.Views.CloturePeriodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Clôture de période"
        Height="480" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{Binding LibellePeriode}" FontSize="18" Style="{StaticResource BrandHeaderText}"/>
        <TextBlock Grid.Row="1" Text="{Binding Resume}" Margin="0,8,0,12" TextWrapping="Wrap" Foreground="#546E7A"/>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Controles}" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Contrôle" Binding="{Binding Libelle}" Width="*"/>
                <DataGridTextColumn Header="Sévérité" Binding="{Binding Severite}" Width="90"/>
                <DataGridTextColumn Header="Détail" Binding="{Binding Message}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Ré-analyser" Command="{Binding AnalyserCommand}" Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,8"/>
            <Button Content="Rouvrir la période" Command="{Binding RouvrirCommand}" Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,8"/>
            <Button Content="Clôturer (forcer avertissements)" Command="{Binding CloturerForcerCommand}" Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,8"/>
            <Button Content="Clôturer la période" Command="{Binding CloturerCommand}"
                    Style="{StaticResource BrandRaisedButton}" Padding="16,10"/>
        </StackPanel>
    </Grid>
</Window>
