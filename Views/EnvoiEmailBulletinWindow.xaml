<Window x:Class="MelodyPaieRDC.Views.EnvoiEmailBulletinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Envoyer le bulletin par e-mail"
        Height="480" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Le bulletin sera envoyé en pièce jointe (PDF). Renseignez le destinataire et les paramètres SMTP." 
                   TextWrapping="Wrap" Margin="0,0,0,16" Foreground="Gray" FontSize="12"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Destinataire (e-mail) *" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtDestinataire" Margin="0,0,0,12" Padding="8,6"/>
                <TextBlock Text="Objet" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtObjet" Margin="0,0,0,12" Padding="8,6"/>
                <TextBlock Text="Message (optionnel)" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtCorps" Margin="0,0,0,16" Padding="8,6" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"/>
                <TextBlock Text="Paramètres SMTP" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="Serveur SMTP *" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtSmtpHost" Margin="0,0,0,8" Padding="8,6"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Port" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtSmtpPort" Margin="0,0,0,0" Padding="8,6" Text="587"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkSsl" Grid.Column="2" Content="SSL/TLS" VerticalAlignment="Bottom" Margin="0,0,0,4" IsChecked="True"/>
                </Grid>
                <TextBlock Text="Expéditeur (e-mail) *" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtSenderEmail" Margin="0,0,0,8" Padding="8,6"/>
                <TextBlock Text="Mot de passe (optionnel)" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtPassword" Margin="0,0,0,0" Padding="8,6"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annuler" Click="Annuler_Click" IsCancel="True"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6" Padding="16,8" Margin="0,0,8,0"/>
            <Button Content="Envoyer" Click="Envoyer_Click" IsDefault="True"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6" Padding="16,8"/>
        </StackPanel>
    </Grid>
</Window>
