<Window x:Class="MelodyPaieRDC.Views.AyantsDroitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Ayants droit"
        Height="480" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4">
                <Run Text="Ayants droit (enfants, conjoint) – "/>
                <Run Text="{Binding NomEmploye}" FontWeight="Bold"/>
            </TextBlock>
            <TextBlock Text="Les enfants à charge sont pris en compte pour la réduction d'impôt (IPR)." 
                       FontSize="12" Foreground="Gray" Margin="0,0,0,12"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="0,8,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Nouvel ayant droit" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,0,8">
                        <TextBlock Text="Nom complet" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding NouveauNom, UpdateSourceTrigger=PropertyChanged}" MaxLength="255"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,0,8">
                        <TextBlock Text="Lien de parenté" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding LiensParente}" SelectedItem="{Binding NouveauLienParente, Mode=TwoWay}" IsEditable="False"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Margin="0,0,0,8">
                        <TextBlock Text="Date de naissance (optionnel)" Margin="0,0,0,2"/>
                        <DatePicker SelectedDate="{Binding NouvelleDateNaissance, Mode=TwoWay}"/>
                    </StackPanel>
                </Grid>
                <Button Content="Ajouter l'ayant droit" Command="{Binding AjouterCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Padding="12,8" HorizontalAlignment="Left" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding AyantsDroit}" SelectedItem="{Binding Selectionne, Mode=TwoWay}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" Margin="0,0,0,12" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                <DataGridTextColumn Header="Lien" Binding="{Binding LienParente}" Width="100"/>
                <DataGridTextColumn Header="Date naissance" Binding="{Binding DateNaissance, StringFormat=dd/MM/yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Supprimer l'ayant droit sélectionné" Command="{Binding SupprimerCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6" Padding="12,8"/>
        </StackPanel>
    </Grid>
</Window>
