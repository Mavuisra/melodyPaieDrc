<Window x:Class="MelodyPaieRDC.Views.PrimesIndemnitesEmployeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:helpers="clr-namespace:MelodyPaieRDC.Helpers"
        Title="Primes et indemnités"
        Height="480" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Window.Resources>
        <helpers:StringToDecimalConverter x:Key="StringToDecimalConverter"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4">
                <Run Text="Primes et indemnités – "/>
                <Run Text="{Binding NomEmploye}" FontWeight="Bold"/>
            </TextBlock>
            <TextBlock Text="Les primes sont ajoutées au bulletin selon les options Imposable (IPR) et Cotisable (CNSS) définies dans le référentiel." 
                       FontSize="12" Foreground="Gray" Margin="0,0,0,12" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Nouvelle affectation" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,0,8">
                        <TextBlock Text="Prime / indemnité" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding PrimesDisponibles}" SelectedItem="{Binding PrimeSelectionnee, Mode=TwoWay}"
                                  DisplayMemberPath="Libelle" IsEditable="False"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,0,8">
                        <TextBlock Text="Montant mensuel" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding Montant, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Converter={StaticResource StringToDecimalConverter}}"/>
                    </StackPanel>
                </Grid>
                <Button Content="Ajouter" Command="{Binding AjouterCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Padding="12,8" HorizontalAlignment="Left" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Affectations}" SelectedItem="{Binding Selectionne, Mode=TwoWay}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" Margin="0,0,0,12" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Prime / indemnité" Binding="{Binding PrimeIndemnite.Libelle}" Width="*"/>
                <DataGridTextColumn Header="Montant" Binding="{Binding Montant, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Imposable" Binding="{Binding PrimeIndemnite.EstImposable}" Width="80"/>
                <DataGridTextColumn Header="Cotisable" Binding="{Binding PrimeIndemnite.EstCotisable}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Supprimer l'affectation sélectionnée" Command="{Binding SupprimerCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6" Padding="12,8"/>
        </StackPanel>
    </Grid>
</Window>
