                                                <materialDesign:PackIcon Kind="FileDelimited" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="CNSS (CSV)" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding ExportDeclarationIprCommand}" Margin="0,4,8,4"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="FileDelimited" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="IPR (CSV)" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding ExportDeclarationCnssExcelCommand}" Margin="0,4,8,4"
