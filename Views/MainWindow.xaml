                                                <materialDesign:PackIcon Kind="Gavel" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="Livre réglementaire (PDF)" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding ExportLivreReglementaireExcelCommand}" Margin="0,4,8,4"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Table" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="Livre réglementaire (Excel)" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
