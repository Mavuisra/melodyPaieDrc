                                                <materialDesign:PackIcon Kind="MicrosoftExcel" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="CNSS (Excel)" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding ExportDeclarationIprExcelCommand}" Margin="0,4,8,4"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="MicrosoftExcel" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="IPR (Excel)" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding ExportLivrePaiePdfCommand}" Margin="0,4,8,4"
