                                                <TextBlock Text="DGI IPR" VerticalAlignment="Center" Foreground="White"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding ExportLivreReglementairePdfCommand}" Margin="0,4,8,4"
