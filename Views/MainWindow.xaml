                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="CloudUpload" Width="18" Height="18" Margin="0,0,8,0" Foreground="White"/>
                                                <TextBlock Text="CNSS e-déclaration" VerticalAlignment="Center" Foreground="White"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding ExportFeuillePaieCnssCommand}" Margin="0,4,8,4"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="FileTable" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="Feuille de paie CNSS" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding ExportDgiIprCommand}" Margin="0,4,8,4"
