                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="N° bulletin" Binding="{Binding NumeroBulletin}" Width="105"/>
                                            <DataGridTextColumn Header="Matricule" Binding="{Binding Employe.Matricule}" Width="90"/>
                                            <DataGridTextColumn Header="Employé" Width="*">
                                                <DataGridTextColumn.Binding>
                                                    <MultiBinding StringFormat="{}{0} {1} {2}">
                                                        <Binding Path="Employe.Nom"/>
                                                        <Binding Path="Employe.Postnom"/>
                                                        <Binding Path="Employe.Prenom"/>
                                                    </MultiBinding>
                                                </DataGridTextColumn.Binding>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Net à payer" Binding="{Binding NetAPayer, StringFormat=N2}" Width="105"/>
                                            <DataGridTextColumn Header="IPR net" Binding="{Binding MontantIprNet, StringFormat=N2}" Width="95"/>
                                            <DataGridTextColumn Header="CNSS ouvrier" Binding="{Binding CotisationCnssOuvrier, StringFormat=N2}" Width="105"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Rapport de paie (menu 8) -->
