<Window x:Class="MelodyPaieRDC.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:MelodyPaieRDC.Views"
        xmlns:helpers="clr-namespace:MelodyPaieRDC.Helpers"
        Title="Melody Paie RDC" Height="620" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Window.Resources>
        <!-- Sidebar : palette cohérente -->
        <SolidColorBrush x:Key="SidebarBrush" Color="#152238"/>
        <SolidColorBrush x:Key="SidebarHoverBrush" Color="#243652"/>
        <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="SidebarAccentBrush" Color="#4FC3F7"/>
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="#8BA3C4"/>
        <helpers:MenuIndexEqualsConverter x:Key="MenuIndexEqualsConverter"/>
        <!-- Libellé de section (non cliquable) -->
        <Style x:Key="SidebarSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#5C7A9E"/>
            <Setter Property="Margin" Value="24,18,16,6"/>
        </Style>
        <!-- Bouton menu : pilule, barre d’accent, état actif renforcé -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8EEF5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="10" Margin="12,2" SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="ActiveGlow" CornerRadius="10" Background="Transparent" Opacity="0"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="AccentBar" Grid.Column="0" Width="4" CornerRadius="2" Margin="10,8,0,8"
                                            Background="{StaticResource SidebarAccentBrush}"
                                            Visibility="Collapsed" VerticalAlignment="Stretch" Opacity="0.95"/>
                                    <Border x:Name="ContentWrap" Grid.Column="1" Padding="14,11,14,11">
                                        <ContentPresenter x:Name="Cp" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarHoverBrush}"/>
                                <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="AccentBar" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="ContentWrap" Property="Padding" Value="18,11,14,11"/>
                            </Trigger>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource MenuIndexEqualsConverter}">
                                        <Binding Path="MenuSelectionne"/>
                                        <Binding Path="Tag" RelativeSource="{RelativeSource TemplatedParent}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarSelectedBrush}"/>
                                <Setter TargetName="ActiveGlow" Property="Background" Value="#18FFFFFF"/>
                                <Setter TargetName="ActiveGlow" Property="Opacity" Value="1"/>
                                <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="AccentBar" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Cards KPI premium : design asymétrique avec accents -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.18"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Cartes indicateurs tableau de bord -->
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E4EAF2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFCFF"/>
                    <Setter Property="BorderBrush" Value="#B8D4F0"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.14"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <helpers:EqualityToVisibilityConverter x:Key="EqualityToVisibilityConverter"/>
        <helpers:StringToDecimalConverter x:Key="StringToDecimalConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="252"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu latéral -->
        <Border Grid.Column="0" ClipToBounds="True" BorderBrush="#335A80" BorderThickness="0,0,1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1A2D47" Offset="0"/>
                    <GradientStop Color="#121C2C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.18" Direction="270" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- En-tête marque -->
                <Border Grid.Row="0" Padding="20,24,20,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="42" Height="42" CornerRadius="12" VerticalAlignment="Top" Margin="0,0,14,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0078D4" Offset="0"/>
                                        <GradientStop Color="#00A6B8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <materialDesign:PackIcon Kind="CalculatorVariant" Width="24" Height="24" Foreground="White"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Melody Paie" FontSize="18" FontWeight="SemiBold" Foreground="White" LineHeight="22"/>
                                <TextBlock Text="République Démocratique du Congo" FontSize="10" Foreground="{StaticResource SidebarMutedBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="#1AFFFFFF" CornerRadius="6" Padding="8,4" Margin="0,14,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="Vue d’ensemble · Temps · RH · Paie · Admin" FontSize="10" Foreground="#B0C4DE" FontWeight="Medium" TextWrapping="Wrap"/>
                        </Border>
                        <TextBlock Text="Entreprise active" FontSize="10" Foreground="{StaticResource SidebarMutedBrush}" Margin="0,16,0,4"/>
                        <TextBlock Text="{Binding EntrepriseCouranteLibelle}" FontSize="12" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                        <ComboBox ItemsSource="{Binding EntreprisesDisponibles}"
                                  SelectedValue="{Binding EntrepriseCouranteId, Mode=TwoWay}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="RaisonSociale"
                                  Margin="0,6,0,0"
                                  Foreground="#1E3A5F"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Height="1" Margin="20,0" VerticalAlignment="Bottom">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#3D5A80" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="0,8,0,8" PanningMode="VerticalOnly">
                    <StackPanel>
                        <!-- 0 — Synthèse -->
                        <TextBlock Text="VUE D'ENSEMBLE" Style="{StaticResource SidebarSectionLabelStyle}" Margin="24,8,16,4"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Tag="0" Command="{Binding SelectionnerMenuCommand}" CommandParameter="0">
                            <DockPanel LastChildFill="True">
                                <materialDesign:PackIcon DockPanel.Dock="Left" Kind="ViewDashboard" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                <TextBlock Text="Tableau de bord" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Button>

                        <!-- 1 — Temps -->
                        <TextBlock Text="TEMPS &amp; PRÉSENCE" Style="{StaticResource SidebarSectionLabelStyle}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Tag="1" Command="{Binding SelectionnerMenuCommand}" CommandParameter="1">
                            <DockPanel LastChildFill="True">
                                <materialDesign:PackIcon DockPanel.Dock="Left" Kind="CalendarClock" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                <TextBlock Text="Pointage journalier" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButtonStyle}" Tag="2" Command="{Binding SelectionnerMenuCommand}" CommandParameter="2">
                            <DockPanel LastChildFill="True">
                                <materialDesign:PackIcon DockPanel.Dock="Left" Kind="Sigma" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                <TextBlock Text="Totaux heures (paie)" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Button>

                        <!-- 3 — RH -->
                        <TextBlock Text="RESSOURCES HUMAINES" Style="{StaticResource SidebarSectionLabelStyle}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Tag="3" Command="{Binding SelectionnerMenuCommand}" CommandParameter="3">
                            <DockPanel LastChildFill="True">
                                <materialDesign:PackIcon DockPanel.Dock="Left" Kind="AccountGroup" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                <TextBlock Text="Employés" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Button>

                        <!-- 4,5,8,7 — Chaîne paie -->
                        <TextBlock Text="PAIE &amp; DÉCLARATIONS" Style="{StaticResource SidebarSectionLabelStyle}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Tag="4" Command="{Binding SelectionnerMenuCommand}" CommandParameter="4">
                            <DockPanel LastChildFill="True">
                                <materialDesign:PackIcon DockPanel.Dock="Left" Kind="Calculator" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                <TextBlock Text="Calcul de paie" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButtonStyle}" Tag="5" Command="{Binding SelectionnerMenuCommand}" CommandParameter="5">
                            <DockPanel LastChildFill="True">
                                <materialDesign:PackIcon DockPanel.Dock="Left" Kind="FileDocument" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                <TextBlock Text="Déclarations CNSS / IPR" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" TextWrapping="Wrap"/>
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButtonStyle}" Tag="8" Command="{Binding SelectionnerMenuCommand}" CommandParameter="8">
                            <DockPanel LastChildFill="True">
                                <materialDesign:PackIcon DockPanel.Dock="Left" Kind="FileChart" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                <TextBlock Text="Rapport de paie" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButtonStyle}" Tag="7" Command="{Binding SelectionnerMenuCommand}" CommandParameter="7">
                            <DockPanel LastChildFill="True">
                                <materialDesign:PackIcon DockPanel.Dock="Left" Kind="Receipt" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                <TextBlock Text="Bulletins générés" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Button>

                        <!-- 6 — Config -->
                        <TextBlock Text="ADMINISTRATION" Style="{StaticResource SidebarSectionLabelStyle}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Tag="6" Command="{Binding SelectionnerMenuCommand}" CommandParameter="6">
                            <DockPanel LastChildFill="True">
                                <materialDesign:PackIcon DockPanel.Dock="Left" Kind="Cog" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                <TextBlock Text="Paramètres" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Zone centrale fond gris clair -->
        <ScrollViewer x:Name="MainContentScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- En-tête section : design statement avec accent dynamique -->
                <Border Grid.Row="0" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Barre accent verticale gradient -->
                        <Border Width="4" CornerRadius="2" VerticalAlignment="Stretch" Margin="0,2,16,2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#00B7C3" Offset="0.5"/>
                                    <GradientStop Color="#107C10" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="11" Foreground="#0078D4" FontWeight="SemiBold" Margin="0,0,0,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="VUE D'ENSEMBLE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="1">
                                                <Setter Property="Text" Value="SUIVI"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="2">
                                                <Setter Property="Text" Value="SUIVI"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="3">
                                                <Setter Property="Text" Value="GESTION"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="4">
                                                <Setter Property="Text" Value="OPÉRATIONS"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="5">
                                                <Setter Property="Text" Value="DÉCLARATIONS"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="6">
                                                <Setter Property="Text" Value="CONFIGURATION"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="7">
                                                <Setter Property="Text" Value="ARCHIVES"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="8">
                                                <Setter Property="Text" Value="RAPPORTS"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock FontSize="26" FontWeight="Light" Foreground="#1A1A1A">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Tableau de bord"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="1">
                                                <Setter Property="Text" Value="Pointage journalier"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="2">
                                                <Setter Property="Text" Value="Totaux heures (paie)"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="3">
                                                <Setter Property="Text" Value="Employés"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="4">
                                                <Setter Property="Text" Value="Calcul de Paie"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="5">
                                                <Setter Property="Text" Value="Déclarations CNSS / IPR"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="6">
                                                <Setter Property="Text" Value="Paramètres"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="7">
                                                <Setter Property="Text" Value="Bulletins générés"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MenuSelectionne}" Value="8">
                                                <Setter Property="Text" Value="Rapport de paie"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- KPI Cards : uniquement sur le tableau de bord pour aérer les autres écrans -->
                <Grid Grid.Row="1" Margin="0,0,0,24">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MenuSelectionne}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Card Masse salariale : accent or/doré -->
                    <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="28,24">
                                <TextBlock Text="Masse salariale totale" FontSize="12" Foreground="#605E5C" FontWeight="Medium" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalMasseSalariale, StringFormat=N0, Mode=OneWay}" FontSize="32" FontWeight="Light" Foreground="#1A1A1A"/>
                                    <TextBlock Text=" USD" FontSize="14" Foreground="#0078D4" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="6,0,0,4"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="1" Width="80" Height="80" CornerRadius="40" VerticalAlignment="Center" Margin="0,0,24,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFD700" Offset="0"/>
                                        <GradientStop Color="#FFA500" Offset="0.5"/>
                                        <GradientStop Color="#E6A800" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <materialDesign:PackIcon Kind="CurrencyUsd" Width="36" Height="36" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    <!-- Card Employés : accent bleu/cyan -->
                    <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="28,24">
                                <TextBlock Text="Effectif" FontSize="12" Foreground="#605E5C" FontWeight="Medium" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding NbEmployes, Mode=OneWay}" FontSize="48" FontWeight="Light" Foreground="#1A1A1A"/>
                                <TextBlock Text="employés" FontSize="13" Foreground="#0078D4" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="80" Height="80" CornerRadius="40" VerticalAlignment="Center" Margin="0,0,24,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0078D4" Offset="0"/>
                                        <GradientStop Color="#00B7C3" Offset="0.5"/>
                                        <GradientStop Color="#106EBE" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <materialDesign:PackIcon Kind="AccountGroup" Width="36" Height="36" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Employés (menu 3) -->
                <Border Grid.Row="2" CornerRadius="14" Padding="0" ClipToBounds="True"
                        BorderBrush="#D6E4F0" BorderThickness="1"
                        Visibility="{Binding MenuSelectionne, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=3}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#F7FAFD" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Bandeau identité visuelle (teinte émeraude / bleu paie) -->
                        <Border Grid.Row="0" Padding="20,16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0D47A1" Offset="0"/>
                                    <GradientStop Color="#00838F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="44" Height="44" CornerRadius="22" Background="#33FFFFFF" Margin="0,0,14,0" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="AccountGroup" Width="26" Height="26" Foreground="White"
                                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Répertoire des employés" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock FontSize="12" Foreground="#E0F7FA" TextWrapping="Wrap" MaxWidth="560" Margin="0,4,0,0">
                                                <Run Text="Entreprise : "/>
                                                <Run Text="{Binding EntrepriseCouranteLibelle, Mode=OneWay}" FontWeight="SemiBold"/>
                                                <Run Text=" — seuls les employés rattachés à cette entreprise sont affichés."/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#26FFFFFF" CornerRadius="20" Padding="14,8" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="AccountMultiple" Width="20" Height="20" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Foreground="White" FontSize="13" VerticalAlignment="Center">
                                                <Run Text="{Binding NbEmployes, Mode=OneWay}" FontWeight="Bold"/>
                                                <Run Text=" enregistré(s)" FontWeight="Normal"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Recherche sous le bandeau -->
                                <Border Grid.Row="1" Margin="0,16,0,0" Background="White" CornerRadius="12" Padding="4,4,4,4"
                                        BorderBrush="#B2DFDB" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
                                    </Border.Effect>
                                    <DockPanel Margin="10,6">
                                        <materialDesign:PackIcon DockPanel.Dock="Left" Kind="Magnify" Width="20" Height="20" Foreground="#00838F" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBox BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" FontSize="14"
                                                 Text="{Binding FiltreEmployes, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Rechercher par matricule, nom, prénom ou département…"/>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Padding="20,16,20,20" Background="Transparent">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Actions : cartes boutons + défilement horizontal si besoin -->
                                <Border Grid.Row="0" Background="#E0F2F1" CornerRadius="12" BorderBrush="#B2DFDB" BorderThickness="1" Padding="12,10" Margin="0,0,0,14">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly">
                                        <WrapPanel Orientation="Horizontal">
                                            <Button Command="{Binding NouvelEmployeCommand}" Margin="0,4,8,4"
                                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="AccountPlus" Width="18" Height="18" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Nouvel employé" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding ModifierEmployeCommand}" Margin="0,4,8,4"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Modifier" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding OuvrirContratsCommand}" Margin="0,4,8,4"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="FileDocument" Width="18" Height="18" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Contrats" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding OuvrirAyantsDroitCommand}" Margin="0,4,8,4"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="AccountChild" Width="18" Height="18" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Ayants droit" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding OuvrirPretsAvancesCommand}" Margin="0,4,8,4"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="CashMultiple" Width="18" Height="18" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Prêts / avances" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding OuvrirPrimesIndemnitesCommand}" Margin="0,4,8,4"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="GiftOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Primes / indemnités" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding OuvrirHeuresMoisEmployeCommand}" Margin="0,4,8,4"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ClockTimeFourOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Heures du mois" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding OuvrirChampsComplementairesEmployeCommand}" Margin="0,4,8,4"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8"
                                                    ToolTip="Champs RH configurables (JSON, sans recompilation)">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="FormTextbox" Width="18" Height="18" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Champs complémentaires" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding SupprimerEmployeCommand}" Margin="0,4,8,4"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Supprimer" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding RafraichirCommand}" Margin="0,4,0,4"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Rafraîchir" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>
                                    </ScrollViewer>
                                </Border>

                                <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" MinHeight="280" VerticalAlignment="Stretch">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06"/>
                                    </Border.Effect>
                                    <!-- Hauteur bornée : sans cela le ScrollViewer parent donne une mesure infinie et la grille désactive la virtualisation des lignes. -->
                                    <DataGrid x:Name="GrilleEmployes"
                                              ItemsSource="{Binding Employes}"
                                              SelectedItem="{Binding EmployeSelectionne, Mode=TwoWay}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#ECEFF1"
                                              Background="Transparent"
                                              RowBackground="White"
                                              AlternatingRowBackground="#EAF4FF"
                                              BorderThickness="0"
                                              RowHeight="38"
                                              MaxHeight="560"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              ScrollViewer.CanContentScroll="True"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              EnableColumnVirtualization="True">
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="SnapsToDevicePixels" Value="True"/>
                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#90CAF9"/>
                                                        <Setter Property="Foreground" Value="#0D47A1"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True"/>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter Property="Background" Value="#64B5F6"/>
                                                    </MultiTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#0D47A1"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="12,10"/>
                                                <Setter Property="BorderBrush" Value="#1565C0"/>
                                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Matricule" Binding="{Binding Matricule}" Width="92"/>
                                            <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="130"/>
                                            <DataGridTextColumn Header="Postnom" Binding="{Binding Postnom}" Width="110"/>
                                            <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="110"/>
                                            <DataGridTextColumn Header="Sexe" Binding="{Binding Sexe}" Width="56"/>
                                            <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="118"/>
                                            <DataGridTextColumn Header="Département" Binding="{Binding Departement.NomDepartement}" Width="150"/>
                                            <DataGridTextColumn Header="Salaire base (USD)" Binding="{Binding SalaireMensuelUsd, StringFormat=N2}" Width="118"/>
                                            <DataGridTextColumn Header="Salaire base (FC)" Binding="{Binding SalaireMensuelCdf, StringFormat=N0}" Width="120"/>
                                            <DataGridTextColumn Header="Salaire / jour (USD)" Binding="{Binding SalaireJourUsd, StringFormat=N2}" Width="128"/>
                                            <DataGridTextColumn Header="Salaire / jour (FC)" Binding="{Binding SalaireJourCdf, StringFormat=N0}" Width="128"/>
                                            <DataGridTextColumn Header="Salaire / h (USD)" Binding="{Binding SalaireHeureUsd, StringFormat=N2}" Width="112"/>
                                            <DataGridTextColumn Header="Salaire / h (FC)" Binding="{Binding SalaireHeureCdf, StringFormat=N0}" Width="112"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Calcul de paie (menu 4) -->
                <Border Grid.Row="2" CornerRadius="14" Padding="0" ClipToBounds="True"
                        BorderBrush="#D6E4F0" BorderThickness="1"
                        Visibility="{Binding MenuSelectionne, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=4}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#F8FAFE" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.10"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Bandeau -->
                        <Border Grid.Row="0" Padding="20,16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4527A0" Offset="0"/>
                                    <GradientStop Color="#1565C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="44" Height="44" CornerRadius="12" Background="#30FFFFFF" Margin="0,0,14,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Calculator" Width="26" Height="26" Foreground="White"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Calcul &amp; bulletins de paie" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="Saisie mensuelle, génération des bulletins et export PDF pour la période choisie."
                                                   FontSize="12" Foreground="#D1C4E9" TextWrapping="Wrap" MaxWidth="520" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#25FFFFFF" CornerRadius="10" Padding="12,8" VerticalAlignment="Center" BorderBrush="#40FFFFFF" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Période active" FontSize="10" Foreground="#E1BEE7"/>
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:D2} / {1}">
                                                    <Binding Path="PeriodeSelectionneePourPaie.Mois" FallbackValue="—"/>
                                                    <Binding Path="PeriodeSelectionneePourPaie.Annee" FallbackValue=""/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="20,16,20,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Période + alerte clôture -->
                            <Grid Grid.Row="0" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="280"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="White" CornerRadius="12" Padding="16,14" BorderBrush="#E4EAF2" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.06"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <materialDesign:PackIcon Kind="CalendarMonth" Width="18" Height="18" Foreground="#5E35B1" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Période de paie" FontWeight="SemiBold" FontSize="13" Foreground="#37474F" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ComboBox ItemsSource="{Binding PeriodesPaie}"
                                                  SelectedItem="{Binding PeriodeSelectionneePourPaie, Mode=TwoWay}"
                                                  IsEditable="False"
                                                  materialDesign:HintAssist.Hint="Mois / année">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <Run Text="{Binding Mois}"/>
                                                        <Run Text="/"/>
                                                        <Run Text="{Binding Annee}"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center"
                                        Background="#FFF3E0" CornerRadius="10" Padding="12,10" BorderBrush="#FFE0B2" BorderThickness="1"
                                        Visibility="{Binding PeriodePaieEstCloturee, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Lock" Width="20" Height="20" Foreground="#E65100" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Cette période est clôturée : la génération de nouveaux bulletins est désactivée. Consultation et PDF restent possibles."
                                                   Foreground="#BF360C" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Actions -->
                            <Border Grid.Row="1" Background="#EDE7F6" CornerRadius="12" BorderBrush="#D1C4E9" BorderThickness="1" Padding="12,10" Margin="0,0,0,14">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly">
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Command="{Binding OuvrirSaisiePaieMoisCommand}" Margin="0,4,8,4"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="TableEdit" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="Saisie de paie (mois)" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding GenererBulletinCommand}" Margin="0,4,8,4"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="FileDocumentMultiple" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="Générer les bulletins" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding VoirBulletinCalculPaieCommand}" Margin="0,4,8,4"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Eye" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="Voir le bulletin" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding TelechargerBulletinCalculPaieCommand}" Margin="0,4,0,4"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="FilePdfBox" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="PDF" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- Liste bulletins -->
                            <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E4EAF2" BorderThickness="1" MinHeight="200" VerticalAlignment="Stretch">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#F3E5F5" BorderBrush="#E1BEE7" BorderThickness="0,0,0,1" Padding="16,12">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FormatListBulleted" Width="20" Height="20" Foreground="#6A1B9A" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Bulletins de la période" FontWeight="SemiBold" FontSize="14" Foreground="#4A148C" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding BulletinsPeriodeCalculPaie}"
                                              SelectedItem="{Binding BulletinSelectionnePourCalculPaie, Mode=TwoWay}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#ECEFF1"
                                              Background="Transparent"
                                              RowBackground="White"
                                              AlternatingRowBackground="#FAFAFC"
                                              BorderThickness="0"
                                              RowHeight="38">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#EDE7F6"/>
                                                <Setter Property="Foreground" Value="#4527A0"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="12,10"/>
                                                <Setter Property="BorderBrush" Value="#D1C4E9"/>
                                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="N° bulletin" Binding="{Binding NumeroBulletin}" Width="110"/>
                                            <DataGridTextColumn Header="Matricule" Binding="{Binding Employe.Matricule}" Width="90"/>
                                            <DataGridTextColumn Header="Employé" Width="*">
                                                <DataGridTextColumn.Binding>
                                                    <MultiBinding StringFormat="{}{0} {1} {2}">
                                                        <Binding Path="Employe.Nom"/>
                                                        <Binding Path="Employe.Postnom"/>
                                                        <Binding Path="Employe.Prenom"/>
                                                    </MultiBinding>
                                                </DataGridTextColumn.Binding>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Net à payer" Binding="{Binding NetAPayer, StringFormat=N2}" Width="110"/>
                                            <DataGridTextColumn Header="IPR net" Binding="{Binding MontantIprNet, StringFormat=N2}" Width="100"/>
                                            <DataGridTextColumn Header="CNSS" Binding="{Binding CotisationCnssOuvrier, StringFormat=N2}" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Déclarations CNSS / IPR (menu 5) -->
                <Border Grid.Row="2" CornerRadius="14" Padding="0" ClipToBounds="True"
                        BorderBrush="#D6E4F0" BorderThickness="1"
                        Visibility="{Binding MenuSelectionne, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=5}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#F5FBF9" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.10"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="20,16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00695C" Offset="0"/>
                                    <GradientStop Color="#00838F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="44" Height="44" CornerRadius="12" Background="#30FFFFFF" Margin="0,0,14,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="FileDocument" Width="26" Height="26" Foreground="White"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Déclarations CNSS &amp; IPR" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="Exports officiels paramétrables (CNSS e-déclaration, DGI IPR, livre arrêté 2008, virements) et clôture avec contrôles."
                                                   FontSize="12" Foreground="#B2DFDB" TextWrapping="Wrap" MaxWidth="520" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#25FFFFFF" CornerRadius="10" Padding="12,8" VerticalAlignment="Center" BorderBrush="#40FFFFFF" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Période déclarée" FontSize="10" Foreground="#B2DFDB"/>
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:D2} / {1}">
                                                    <Binding Path="PeriodeSelectionneePourDeclarations.Mois" FallbackValue="—"/>
                                                    <Binding Path="PeriodeSelectionneePourDeclarations.Annee" FallbackValue=""/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="20,16,20,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="280"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="White" CornerRadius="12" Padding="16,14" BorderBrush="#E0F2F1" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.05"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
