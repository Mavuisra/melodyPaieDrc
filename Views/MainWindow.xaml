                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#E0F2F1" BorderBrush="#B2DFDB" BorderThickness="0,0,0,1" Padding="16,12">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ClipboardList" Width="20" Height="20" Foreground="#00695C" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Bulletins de la période" FontWeight="SemiBold" FontSize="14" Foreground="#004D40" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding BulletinsPeriode}"
