                                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#01579B">
                                            <Run Text="{Binding DeclarationTotalCnss, StringFormat=N0, Mode=OneWay}"/><Run Text=" USD" FontSize="11"/>
