                                                <materialDesign:PackIcon Kind="CreditCard" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="Fichier virements" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding OuvrirCloturePeriodeCommand}" Margin="0,4,8,4"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" materialDesign:ButtonAssist.CornerRadius="8" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="LockCheck" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="Clôturer la période" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding OuvrirGuideCnssCommand}" Margin="0,4,8,4"
                                                Style="{StaticResource MaterialDesignFlatButton}" Padding="10,8">
                                            <TextBlock Text="Guide CNSS" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Command="{Binding OuvrirGuideIprCommand}" Margin="0,4,0,4"
                                                Style="{StaticResource MaterialDesignFlatButton}" Padding="10,8">
                                            <TextBlock Text="Guide IPR DGI" VerticalAlignment="Center"/>
                                        </Button>
                                    </WrapPanel>
                                </ScrollViewer>
                            </Border>

                            <Border Grid.Row="3" Background="White" CornerRadius="12" BorderBrush="#E4EAF2" BorderThickness="1" MinHeight="180" VerticalAlignment="Stretch">
