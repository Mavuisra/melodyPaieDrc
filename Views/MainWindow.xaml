                                                <materialDesign:PackIcon Kind="BookOpenVariant" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="Livre (Excel)" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding ExportCnssEdeclarationCommand}" Margin="0,4,8,4"
                                                Style="{StaticResource MaterialDesignRaisedButton}" Background="#00695C" Foreground="White"
