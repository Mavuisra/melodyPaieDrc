<UserControl x:Class="MelodyPaieRDC.Views.DynamicFormControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FieldsPanel" Margin="0,0,4,0"/>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Recharger JSON" Command="{Binding RechargerMetadonneesCommand}"
                    Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Annuler" Command="{Binding AnnulerCommand}" IsCancel="True"
                    Margin="0,0,8,0" Padding="16,6"/>
            <Button Content="Enregistrer" Command="{Binding EnregistrerCommand}" IsDefault="True"
                    Padding="16,6" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</UserControl>
