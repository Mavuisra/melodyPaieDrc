<UserControl x:Class="MelodyPaieRDC.Views.SuiviJournalierPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:MelodyPaieRDC.Helpers"
             xmlns:models="clr-namespace:MelodyPaieRDC.Models"
             xmlns:views="clr-namespace:MelodyPaieRDC.Views"
             Background="Transparent"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
             FontFamily="{materialDesign:MaterialDesignFont}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.10" Color="#0F172A"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="BorderBrush" Value="#2563EB"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.20" Color="#2563EB"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PresenceRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F1F5F9"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="BorderBrush" Value="#93C5FD"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#BFDBFE"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PresenceColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E3A8A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#1E40AF"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailMoisRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECFDF5"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D1FAE5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PointageBadgeStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="Marquer les pointages comme lus"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.4" Color="#7F1D1D"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.55" Color="#7F1D1D"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PointageChipButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1E3A5F"/>
            <Setter Property="BorderBrush" Value="#C7D2FE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PointageChipPrimaryStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BrandPrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrandPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BrandPrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PointageToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource PointageChipButtonStyle}"/>
        <x:Array x:Key="TypesJourSuivi" Type="{x:Type sys:String}">
            <sys:String>Normal</sys:String>
            <sys:String>Congé de circonstance</sys:String>
            <sys:String>Maladie</sys:String>
            <sys:String>Préavis</sys:String>
        </x:Array>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,4,8">

            <!-- Filtres + actions (style cohérent avec bandeau LIVE) -->
            <Border CornerRadius="12" Margin="0,0,0,10" BorderBrush="#C7D2FE" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8FAFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="#1E3A5F"/>
                </Border.Effect>
                <StackPanel Margin="14,12">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="160" MaxWidth="220"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="2*" MinWidth="280"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <materialDesign:PackIcon Kind="CalendarMonth" Width="16" Height="16" Foreground="#3B82F6" Margin="0,0,6,0"/>
                                <TextBlock Text="Période" FontSize="11" FontWeight="SemiBold" Foreground="#64748B"/>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding PeriodesPaie}"
                                      SelectedItem="{Binding PeriodeSelectionnee, Mode=TwoWay}"
                                      materialDesign:HintAssist.Hint="Mois / année">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13">
                                            <Run Text="{Binding Mois, Mode=OneWay}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding Annee, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <materialDesign:PackIcon Kind="AccountSearch" Width="16" Height="16" Foreground="#3B82F6" Margin="0,0,6,0"/>
                                <TextBlock Text="Employé (clic tableau ou liste)" FontSize="11" FontWeight="SemiBold" Foreground="#64748B"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="120"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="1.4*" MinWidth="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding RechercheEmployeText, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Matricule, nom…"/>
                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding Employes}"
                                          SelectedItem="{Binding EmployeSelectionne, Mode=TwoWay}"
                                          materialDesign:HintAssist.Hint="Sélectionner">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:Employe}">
                                            <TextBlock TextTrimming="CharacterEllipsis" FontSize="13">
                                                <Run Text="{Binding Matricule, Mode=OneWay}" FontWeight="SemiBold"/>
                                                <Run Text=" — "/>
                                                <Run Text="{Binding Nom, Mode=OneWay}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Prenom, Mode=OneWay}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#E2E8F0" Margin="0,0,0,10"/>
                    <TextBlock Text="Actions" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <Button Command="{Binding RafraichirPresenceCommand}"
                                Style="{StaticResource PointageChipPrimaryStyle}"
                                ToolTip="Synchroniser le terminal ZKTeco">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CloudSync" Width="15" Height="15" Margin="0,0,6,0"/>
                                <TextBlock Text="Synchroniser"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ImporterUtilisateursTerminalCommand}"
                                Style="{StaticResource PointageChipButtonStyle}"
                                ToolTip="Importer les utilisateurs du terminal">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountArrowDown" Width="15" Height="15" Margin="0,0,6,0"/>
                                <TextBlock Text="Importer terminal"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ActualiserListesCommand}"
                                Style="{StaticResource PointageChipButtonStyle}"
                                ToolTip="Recharger employés et périodes">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="15" Height="15" Margin="0,0,6,0"/>
                                <TextBlock Text="Actualiser"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ForcerPeriodeMoisCourantCommand}"
                                Style="{StaticResource PointageChipButtonStyle}"
                                ToolTip="Passer au mois en cours">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarToday" Width="15" Height="15" Margin="0,0,6,0"/>
                                <TextBlock Text="Mois en cours"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ChargerLignesCommand}"
                                Style="{StaticResource PointageChipButtonStyle}"
                                ToolTip="Afficher le détail mensuel">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TableEye" Width="15" Height="15" Margin="0,0,6,0"/>
                                <TextBlock Text="Détail mois"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RetablirCalculAutomatiqueCommand}"
                                Style="{StaticResource PointageChipButtonStyle}"
                                ToolTip="Recalcul automatique des heures">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Calculator" Width="15" Height="15" Margin="0,0,6,0"/>
                                <TextBlock Text="Recalcul LT"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding EffacerEmployeSelectionneCommand}"
                                Style="{StaticResource PointageChipButtonStyle}"
                                ToolTip="Retirer l'employé sélectionné">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountRemove" Width="15" Height="15" Margin="0,0,6,0"/>
                                <TextBlock Text="Effacer"/>
                            </StackPanel>
                        </Button>
                        <Button Click="ExporterPdf_Click"
                                Style="{StaticResource PointageChipButtonStyle}"
                                ToolTip="Exporter PDF — pointés aujourd'hui">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FilePdfBox" Width="15" Height="15" Margin="0,0,6,0"/>
                                <TextBlock Text="PDF jour"/>
                            </StackPanel>
                        </Button>
                        <Button Click="ExporterPdfTousEmployes_Click"
                                Style="{StaticResource PointageChipButtonStyle}"
                                ToolTip="Exporter PDF — toute la période">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocumentMultiple" Width="15" Height="15" Margin="0,0,6,0"/>
                                <TextBlock Text="PDF période"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- DASHBOARD LIVE MODERNE -->
            <Border Background="#EEF2FF" CornerRadius="12" Padding="14,12" Margin="0,0,0,8"
                    BorderBrush="#C7D2FE" BorderThickness="1">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="#22C55E" Margin="0,0,8,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.35" Duration="0:0:0.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="LIVE" FontWeight="Bold" FontSize="11" Foreground="#15803D" Margin="0,0,10,0"/>
                            <TextBlock Text="Présence en direct" FontWeight="Bold" FontSize="16" Foreground="#0F172A"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding BasculerSonPointageCommand}"
                                    Style="{StaticResource PointageChipButtonStyle}"
                                    Margin="0,0,6,0"
                                    ToolTip="Activer ou couper le son à chaque pointage">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="VolumeHigh" Width="14" Height="14" Margin="0,0,4,0"
                                                             Visibility="{Binding SonPointageActif, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <materialDesign:PackIcon Kind="VolumeOff" Width="14" Height="14" Margin="0,0,4,0">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SonPointageActif}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                    <TextBlock Text="{Binding SonPointageLibelle}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RafraichirPresenceCommand}"
                                    Style="{StaticResource PointageChipButtonStyle}"
                                    Margin="0,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Réessayer" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ReinitialiserBadgePointageCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Padding="4,2"
                                    ToolTip="Marquer comme lu"
                                    Visibility="{Binding AfficherBadgePointagesNonLus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Style="{StaticResource PointageBadgeStyle}">
                                    <TextBlock Text="{Binding BadgePointagesNonLusLibelle}" FontSize="10" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="4">
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Terminal" Foreground="#475569" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TerminalEtatTitre}" FontWeight="Bold" FontSize="14" Margin="0,4,0,2" Foreground="#0F172A"/>
                                <TextBlock Text="{Binding ZkStatutSync}" FontSize="11" Foreground="#334155"/>
                                <TextBlock Text="{Binding TerminalEtatMessageCourt}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{Binding TerminalEtatCouleur}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Employés pointés" Foreground="#475569" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding NbEmployesPresentsAujourdhui}" FontSize="28" FontWeight="Bold" Foreground="#047857"/>
                                <TextBlock Text="Aujourd'hui" FontSize="11" Foreground="#334155"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Temps moyen" Foreground="#475569" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding HeuresMoyennesAujourdhuiLibelle}" FontSize="28" FontWeight="Bold" Foreground="#1D4ED8"/>
                                <TextBlock Text="Par employé actif" FontSize="11" Foreground="#334155"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardCardStyle}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Retards" Foreground="#475569" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding NbRetardsAujourdhui}" FontSize="28" FontWeight="Bold" Foreground="#DC2626"/>
                                <TextBlock Text="Début de journée" FontSize="11" Foreground="#334155"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{Binding PresenceStatut}" Foreground="#1E293B" FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center"/>
                        <Button Command="{Binding BasculerDiagnosticCommand}" Margin="12,0,0,0"
                                Style="{StaticResource MaterialDesignFlatButton}" Padding="8,2" FontSize="11"
                                Visibility="{Binding TerminalHorsLigne, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding BoutonDiagnosticLibelle}"/>
                        </Button>
                    </StackPanel>
                    <Border Background="#FFF5F5" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="10" Padding="10,8"
                            Visibility="{Binding DiagnosticTechniqueVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding DiagnosticTechniqueTerminal}" FontSize="11" Foreground="#7F1D1D" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#94A3B8" BorderThickness="1" Padding="14,10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Activité par heure (aujourd'hui)" FontWeight="Bold" FontSize="13" Foreground="#0F172A"/>
                    <ItemsControl ItemsSource="{Binding PresenceParHeure}" Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="15"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="2,0">
                                    <Border Width="16" Height="{Binding Hauteur}" CornerRadius="6,6,2,2" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2563EB"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1D4ED8"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.35" Color="#1E40AF"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding NombrePointages}" Value="0">
                                                        <Setter Property="Background" Value="#CBD5E1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding HeureLabel}" FontSize="9.5" FontWeight="SemiBold"
                                               Foreground="#334155" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#94A3B8" BorderThickness="1" Padding="0"
                    MinHeight="220" MaxHeight="420" Margin="0,0,0,10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.09" Color="{DynamicResource BrandPrimaryColor}"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="14,10" CornerRadius="12,12,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E8F5E9" Offset="0"/>
                                <GradientStop Color="#E3F2FD" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="{Binding PresenceResumeDureesAujourdhui}" FontSize="12.5"
                                       Foreground="#1E293B" TextWrapping="Wrap" LineHeight="18" FontWeight="Medium"/>
                            <TextBlock Text="Cliquez une ligne pour suivre le mois de cet employé."
                                       FontSize="11.5" Foreground="#1D4ED8" FontWeight="Bold" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding PresenceLegendeColonnes}" FontSize="11" Foreground="#475569"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <DataGrid x:Name="GrillePresenceSynthese" Grid.Row="1"
                              ItemsSource="{Binding PresenceSyntheseEmployes}"
                              SelectionChanged="GrillePresenceSynthese_SelectionChanged"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              AlternationCount="2"
                              RowBackground="#FFFFFF"
                              AlternatingRowBackground="#F8FAFC"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#CBD5E1"
                              RowHeight="44" BorderThickness="0">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource PresenceRowStyle}"/>
                        </DataGrid.RowStyle>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource PresenceColumnHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Employé" Width="*" MinWidth="200" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="28" Height="28" CornerRadius="14" Background="#DBEAFE" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Initiales}" Foreground="#1D4ED8" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                                            </Border>
                                            <TextBlock Text="{Binding NomComplet}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                            <Border Margin="8,0,0,0" CornerRadius="10" Padding="8,2" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Setter Property="BorderBrush" Value="#81C784"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EstRetard}" Value="True">
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                                <Setter Property="BorderBrush" Value="#E57373"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding IndicateurRetard}" FontSize="10.5" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Entrée" Width="88" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="8,3" Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#15803D"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#166534"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Entree}" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn x:Name="ColDebutPause" Header="Début pause" Width="88" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="8,3" Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#C2410C"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#9A3412"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding DebutPause}" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn x:Name="ColFinPause" Header="Fin pause" Width="88" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="8,3" Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1D4ED8"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#1E3A8A"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding FinPause}" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Sortie" Width="88" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="8,3" Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#7E22CE"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#6B21A8"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Sortie}" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Matricule" Binding="{Binding Matricule}" Width="90" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Statut" Width="140" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="8,3" Background="#10B981">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Statut}" Value="Non reconnu Melody">
                                                            <Setter Property="Background" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding EstRetard}" Value="True">
                                                            <Setter Property="Background" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="White">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Présent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Statut}" Value="Non reconnu Melody">
                                                                <Setter Property="Text" Value="Non reconnu"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding EstRetard}" Value="True">
                                                                <Setter Property="Text" Value="Présent (retard)"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Détail mois — visible seulement si employé choisi -->
            <Border Background="#F8FAFC" CornerRadius="12" Padding="14,12" BorderBrush="#E2E8F0" BorderThickness="1"
                    Visibility="{Binding AfficherDetailMois, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="CalendarMonth" Width="20" Height="20" Foreground="#0D9488" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ContexteSaisieLibelle}" FontWeight="SemiBold" FontSize="13" Foreground="#0F766E" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalHeuresMoisLibelle}" Margin="16,0,0,0" FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Mis à jour automatiquement après chaque synchro terminal. Les corrections manuelles s’enregistrent avec le bouton ci-dessous."
                               FontSize="11" Foreground="#78909C" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding Lignes}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              MaxHeight="280"
                              AlternationCount="2"
                              RowHeight="36"
                              Background="White"
                              RowBackground="#FFFFFF"
                              AlternatingRowBackground="#F8FAFC"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#CBD5E1"
                              BorderBrush="#94A3B8" BorderThickness="1">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DetailMoisRowStyle}"/>
                        </DataGrid.RowStyle>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource PresenceColumnHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding DateAffichage}" Width="95" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Jour" Binding="{Binding JourSemaine}" Width="110" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Mode" Binding="{Binding ModeCalculLibelle}" Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Heures" Binding="{Binding HeuresPrestees, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                            <DataGridComboBoxColumn Header="Type jour" Width="*"
                                                    ItemsSource="{StaticResource TypesJourSuivi}"
                                                    SelectedItemBinding="{Binding TypeJour, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Command="{Binding RetablirCalculAutomatiqueCommand}"
                                Style="{StaticResource PointageToolbarButtonStyle}"
                                Padding="14,8" Margin="0,0,8,0"
                                ToolTip="Recalculer les heures depuis les pointages enregistrés (LT)">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Calculator" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="Recalcul auto (LT)"/>
                            </StackPanel>
                        </Button>
                        <Button Click="ExporterPdfTousEmployes_Click"
                                Style="{StaticResource PointageToolbarButtonStyle}"
                                Padding="14,8" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocumentMultiple" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="PDF période (tous)"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding EnregistrerCommand}"
                                Style="{StaticResource BrandRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="8" Padding="18,10">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0"/>
                                <TextBlock Text="Enregistrer ce mois"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#FFFDE7" CornerRadius="10" Padding="14,12" BorderBrush="#FFF59D" BorderThickness="1"
                    Margin="0,0,0,4"
                    Visibility="{Binding AfficherInviteSelectionEmploye, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="GestureTap" Width="22" Height="22" Foreground="#F9A825" Margin="0,0,10,0"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#5D4037" FontSize="12" VerticalAlignment="Center">
                        <Run Text="Pour le détail mensuel : cliquez un employé dans le tableau « Présence en direct » ou choisissez-le dans la liste."/>
                        <LineBreak/>
                        <Run Text="Les totaux de tous les employés restent dans le menu « Totaux d'heures pour la paie »." FontStyle="Italic"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding MessageVide}" Foreground="#78909C" FontSize="12" TextWrapping="Wrap"
                       TextAlignment="Center" Margin="12,8"
                       Visibility="{Binding MessageVide, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>
    </ScrollViewer>
        <views:PointageLiveToastOverlay Panel.ZIndex="20"/>
    </Grid>
</UserControl>
