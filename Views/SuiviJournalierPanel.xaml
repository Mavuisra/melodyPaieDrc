<UserControl x:Class="MelodyPaieRDC.Views.SuiviJournalierPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:MelodyPaieRDC.Helpers"
             Background="Transparent"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
             FontFamily="{materialDesign:MaterialDesignFont}">
    <UserControl.Resources>
        <helpers:StringToDecimalConverter x:Key="StringToDecimalConverter"/>
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <x:Array x:Key="TypesJourSuivi" Type="{x:Type sys:String}">
            <sys:String>Normal</sys:String>
            <sys:String>Congé de circonstance</sys:String>
            <sys:String>Maladie</sys:String>
            <sys:String>Préavis</sys:String>
        </x:Array>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#EEF4FA" CornerRadius="10" Padding="12,10" Margin="0,0,0,10" BorderBrush="#DDE8F2" BorderThickness="1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Fingerprint" Width="20" Height="20" Foreground="#1E3A5F" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Présence en direct" FontWeight="SemiBold" FontSize="13" Foreground="#37474F" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Background="#E8F5E9" CornerRadius="8" Padding="10,6" Margin="0,0,8,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Autorenew" Width="18" Height="18" Foreground="#2E7D32" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock FontSize="12" Foreground="#37474F" VerticalAlignment="Center">
                                    <Run Text="Auto · cycle "/>
                                    <Run Text="3 s" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ProgressBar Width="150" Height="8" Margin="0,12,0,0" IsIndeterminate="{Binding PresenceSynchronisationEnCours}"/>
                        <Button Content="Importer utilisateurs terminal"
                                Command="{Binding ImporterUtilisateursTerminalCommand}"
                                Margin="10,0,0,0"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Padding="14,6"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Text="{Binding PresenceStatut}" Foreground="#546E7A" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#C5D4E8" BorderThickness="1" Padding="0" MinHeight="280"
                VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.09" Color="#1E3A5F"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="14,12" CornerRadius="12,12,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E8F5E9" Offset="0"/>
                            <GradientStop Color="#E3F2FD" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <materialDesign:PackIcon Kind="ClockOutline" Width="18" Height="18" Foreground="#1565C0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Synthèse du jour (durées)" FontWeight="SemiBold" FontSize="13" Foreground="#1565C0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding PresenceResumeDureesAujourdhui}" FontSize="12.5" Foreground="#37474F" TextWrapping="Wrap" LineHeight="18"/>
                    </StackPanel>
                </Border>
                <DataGrid Grid.Row="1" ItemsSource="{Binding PresenceSyntheseEmployes}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          Background="Transparent"
                          RowBackground="#FFFFFF"
                          AlternatingRowBackground="#F1F8FF"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#CFD8DC"
                          RowHeight="40"
                          BorderThickness="0"
                          VerticalAlignment="Stretch">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#BBDEFB"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="#90CAF9"/>
                                </MultiTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1E3A5F"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,11"/>
                            <Setter Property="BorderBrush" Value="#2E4A6F"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Jour" Binding="{Binding Jour}" Width="110" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Employé" Width="280" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding NomComplet}" FontWeight="SemiBold" FontSize="13" Foreground="#0F172A" VerticalAlignment="Center"/>
                                        <Border Margin="8,0,0,0" CornerRadius="10" Padding="8,2" BorderThickness="1" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                    <Setter Property="BorderBrush" Value="#81C784"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EstRetard}" Value="True">
                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                            <Setter Property="BorderBrush" Value="#E57373"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding IndicateurRetard}" FontSize="10.5" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EstRetard}" Value="True">
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Entrée" Width="120" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Center" Background="#43A047" BorderBrush="#1B5E20" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#43A047"/>
                                                <Setter Property="BorderBrush" Value="#1B5E20"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EstRetard}" Value="True">
                                                        <Setter Property="Background" Value="#E53935"/>
                                                        <Setter Property="BorderBrush" Value="#B71C1C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Entree}" Value="—">
                                                        <Setter Property="Background" Value="#B0BEC5"/>
                                                        <Setter Property="BorderBrush" Value="#607D8B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Entree}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Début pause" Width="120" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Center" Background="#FB8C00" BorderBrush="#E65100" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FB8C00"/>
                                                <Setter Property="BorderBrush" Value="#E65100"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DebutPause}" Value="—">
                                                        <Setter Property="Background" Value="#B0BEC5"/>
                                                        <Setter Property="BorderBrush" Value="#607D8B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding DebutPause}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Fin pause" Width="120" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Center" Background="#1E88E5" BorderBrush="#0D47A1" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1E88E5"/>
                                                <Setter Property="BorderBrush" Value="#0D47A1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FinPause}" Value="—">
                                                        <Setter Property="Background" Value="#B0BEC5"/>
                                                        <Setter Property="BorderBrush" Value="#607D8B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding FinPause}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Sortie" Width="120" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Center" Background="#8E24AA" BorderBrush="#4A148C" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#8E24AA"/>
                                                <Setter Property="BorderBrush" Value="#4A148C"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Sortie}" Value="—">
                                                        <Setter Property="Background" Value="#B0BEC5"/>
                                                        <Setter Property="BorderBrush" Value="#607D8B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Sortie}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Autres" Width="140" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Center" Background="#546E7A" BorderBrush="#37474F" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#546E7A"/>
                                                <Setter Property="BorderBrush" Value="#37474F"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Autres}" Value="—">
                                                        <Setter Property="Background" Value="#CFD8DC"/>
                                                        <Setter Property="BorderBrush" Value="#90A4AE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Autres}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Matricule" Binding="{Binding Matricule}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Département" Binding="{Binding Departement}" Width="130" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Statut" Width="155" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Left">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.18" Color="#000000"/>
                                        </Border.Effect>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#90A4AE"/>
                                                <Setter Property="BorderBrush" Value="#546E7A"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Statut}" Value="Reconnu Melody">
                                                        <Setter Property="Background" Value="#00C853"/>
                                                        <Setter Property="BorderBrush" Value="#1B5E20"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Statut}" Value="Non reconnu Melody">
                                                        <Setter Property="Background" Value="#F44336"/>
                                                        <Setter Property="BorderBrush" Value="#B71C1C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Statut}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Exporter pointés aujourd'hui (PDF)"
                    Click="ExporterPdf_Click"
                    Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Padding="20,10"
                    ToolTip="Exporte uniquement les personnels qui ont pointé aujourd'hui.">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FilePdfBox" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button Content="PDF tous employés"
                    Click="ExporterPdfTousEmployes_Click"
                    Margin="0,0,12,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Padding="14,10"
                    ToolTip="Un PDF : récap des heures pour tous les employés + une page détail par personne (données enregistrées en base pour la période choisie).">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocumentMultiple" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button Content="Enregistrer le mois"
                    Command="{Binding EnregistrerCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Padding="20,10">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
