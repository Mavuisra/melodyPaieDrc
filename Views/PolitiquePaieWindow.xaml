<Window x:Class="MelodyPaieRDC.Views.PolitiquePaieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Politique de paie (configurable)"
        Height="620" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Politique de paie active" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.75" Margin="0,6,0,0"
                       Text="Règles de calcul sans modifier le code : jours de référence, présence, rubriques bulletin. Spécifique à l'entreprise courante."/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" IsEnabled="{Binding PeutModifier}">
            <StackPanel>
                <TextBox materialDesign:HintAssist.Hint="Libellé de la politique"
                         Text="{Binding LibellePolitique, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <UniformGrid Columns="2" Margin="0,0,0,12">
                    <TextBox materialDesign:HintAssist.Hint="Jours de référence paie (ex. 26)"
                             Text="{Binding JoursReferencePaie, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                    <TextBox materialDesign:HintAssist.Hint="Heures par jour (ex. 8)"
                             Text="{Binding HeuresParJour, UpdateSourceTrigger=PropertyChanged}" Margin="8,0,0,0"/>
                </UniformGrid>
                <ComboBox materialDesign:HintAssist.Hint="Mode calcul présence"
                          SelectedValue="{Binding ModeCalculPresence}" SelectedValuePath="Tag" Margin="0,0,0,12">
                    <ComboBoxItem Content="Pointages terminal (ZKTeco)" Tag="POINTAGES_TERMINAL"/>
                    <ComboBoxItem Content="Saisie des jours" Tag="SAISIE_JOURS"/>
                    <ComboBoxItem Content="Hybride" Tag="HYBRIDE"/>
                </ComboBox>
                <CheckBox Content="Salaire du contrat exprimé en net" IsChecked="{Binding SalaireContratEnNet}" Margin="0,4"/>
                <CheckBox Content="Utiliser le barème IPR en base" IsChecked="{Binding UtiliserBaremeIpr}" Margin="0,4"/>
                <CheckBox Content="Utiliser les taux sociaux en base (CNSS, INPP…)" IsChecked="{Binding UtiliserTauxSociauxDb}" Margin="0,4,12,12"/>
                <TextBlock Text="Rubriques du bulletin (libellés et ordre)" FontWeight="SemiBold" Margin="0,8,0,8"/>
                <DataGrid ItemsSource="{Binding Rubriques}" AutoGenerateColumns="False" CanUserAddRows="False"
                          HeadersVisibility="Column" MaxHeight="220" Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code" Binding="{Binding Code}" IsReadOnly="True" Width="140"/>
                        <DataGridTextColumn Header="Libellé" Binding="{Binding Libelle, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Ordre" Binding="{Binding OrdreAffichage, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                        <DataGridCheckBoxColumn Header="Bulletin" Binding="{Binding AfficherSurBulletin, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="2" Content="Enregistrer la politique" Command="{Binding EnregistrerCommand}"
                HorizontalAlignment="Right" Margin="0,16,0,0"
                Style="{StaticResource MaterialDesignRaisedButton}" Padding="20,10"/>
    </Grid>
</Window>
