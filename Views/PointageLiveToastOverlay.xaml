<UserControl x:Class="MelodyPaieRDC.Views.PointageLiveToastOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:services="clr-namespace:MelodyPaieRDC.Services"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <Style x:Key="ToastCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="4" Opacity="0.18" Color="#1A237E"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EstRetard}" Value="True">
                    <Setter Property="BorderBrush" Value="#FCA5A5"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Background" Value="#FEF2F2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ItemsControl ItemsSource="{x:Static services:PointageLiveNotificationService.Toasts}"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,12,12,0"
                  MaxWidth="360">
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type services:PointageToastItem}">
                <Border Style="{StaticResource ToastCardStyle}">
                    <Border.RenderTransform>
                        <TranslateTransform X="26"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0" To="1"
                                                     Duration="0:0:0.24"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                     From="26" To="0"
                                                     Duration="0:0:0.24"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                                Background="{Binding CouleurAccent}" Margin="0,0,12,0">
                            <TextBlock Text="{Binding Initiales}" FontWeight="Bold" FontSize="14"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding NomComplet}" FontWeight="Bold" FontSize="14"
                                       Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding SousTitre}" FontSize="11" Foreground="#475569" Margin="0,2,0,6"/>
                            <Border CornerRadius="8" Padding="8,3" HorizontalAlignment="Left"
                                    Background="{Binding CouleurAccent}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Width="14" Height="14"
                                                             Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="Login"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EstRetard}" Value="True">
                                                        <Setter Property="Kind" Value="ClockAlert"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Moment}" Value="Sortie">
                                                        <Setter Property="Kind" Value="Logout"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Moment}" Value="Pause">
                                                        <Setter Property="Kind" Value="Coffee"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Moment}" Value="Début pause">
                                                        <Setter Property="Kind" Value="Coffee"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Moment}" Value="Fin pause">
                                                        <Setter Property="Kind" Value="CoffeeOutline"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                    <TextBlock Text="{Binding Moment}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding HeureAffichage}" FontSize="20" FontWeight="Bold"
                                       Foreground="#1D4ED8" HorizontalAlignment="Right"/>
                            <TextBlock Text="à l'instant" FontSize="10" Foreground="#64748B" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
