<Window x:Class="MelodyPaieRDC.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Connexion - Melody Paie RDC"
        Height="470" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F2F5"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Border Background="#F0F2F5" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Margin="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Bandeau titre avec logo MelodyPaie -->
            <Border Grid.Row="0" Background="#1E3A5F" CornerRadius="8,8,0,0" Padding="28,32">
                <StackPanel HorizontalAlignment="Center">
                    <Border Background="White" CornerRadius="50" Padding="8" Margin="0,0,0,14">
                        <Image Source="pack://application:,,,/MelodyPaieRDC;component/Assets/Icon_MelodyPaie.png"
                               Width="56" Height="56" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="Melody Paie RDC" FontSize="24" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Connectez-vous pour continuer" FontSize="13" Foreground="#B0BEC5" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Formulaire dans une carte -->
            <Border Grid.Row="1" Margin="24,20,24,24" Background="White" CornerRadius="10" Padding="28,24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Identifiant" FontSize="12" Foreground="#546E7A" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtLogin" Padding="12,10" FontSize="14" TabIndex="0"
                                 materialDesign:HintAssist.Hint="Votre identifiant"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,24">
                        <TextBlock Text="Mot de passe" FontSize="12" Foreground="#546E7A" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="TxtPassword" Padding="12,10" FontSize="14" MinHeight="36"
                                     TabIndex="1" materialDesign:HintAssist.Hint="Mot de passe"
                                     Foreground="#212121"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="11" Foreground="#78909C" Margin="0,0,0,16"
                               Text="Utilisez l'identifiant et le mot de passe définis lors de la configuration initiale. En cas d'oubli, contactez l'administrateur de votre organisation."/>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Annuler" IsCancel="True" Click="Annuler_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="8" Padding="24,10" Margin="0,0,12,0"/>
                        <Button Content="Connexion" IsDefault="True" Click="Connexion_Click"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#1E3A5F"
                                materialDesign:ButtonAssist.CornerRadius="8" Padding="24,10"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
