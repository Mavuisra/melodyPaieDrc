<Window x:Class="MelodyPaieRDC.Views.AssistantConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:helpers="clr-namespace:MelodyPaieRDC.Helpers"
        Title="Étape 1/2 — Configuration de votre entreprise"
        Height="720" Width="640"
        MinHeight="640" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Window.Resources>
        <helpers:PathToImageSourceConverter x:Key="PathToImageSourceConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="{Binding Titre}" FontSize="22" Style="{StaticResource BrandHeaderText}"/>
            <TextBlock Text="{Binding SousTitreEtape}" FontSize="14" Foreground="#00838F" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding IndicateurEtapes}" FontSize="11" Foreground="#78909C" Margin="0,8,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#E3F2FD" CornerRadius="8" Padding="12" Margin="0,8,0,12">
            <TextBlock Text="{Binding MessageEtat}" TextWrapping="Wrap" Foreground="#1565C0" FontSize="12"/>
        </Border>

        <!-- Contenu des étapes -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Étape 1 : Identité légale -->
                <Border Background="White" CornerRadius="10" Padding="20"
                        Visibility="{Binding EstEtape1, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <TextBlock Text="Informations légales et coordonnées" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"/>
                        <TextBox materialDesign:HintAssist.Hint="Raison sociale *" Text="{Binding RaisonSociale, UpdateSourceTrigger=PropertyChanged}"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="NIF" Text="{Binding Nif, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="RCCM" Text="{Binding Nrc, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBox materialDesign:HintAssist.Hint="ID. National" Text="{Binding IdNat, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="N° CNSS employeur" Text="{Binding NumCnss, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="N° INPP" Text="{Binding NumInpp, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBox materialDesign:HintAssist.Hint="N° affiliation CNSS" Text="{Binding NumeroAffiliationCnss, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>
                        <TextBox materialDesign:HintAssist.Hint="Adresse" Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Téléphone" Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="E-mail" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBox materialDesign:HintAssist.Hint="Site web" Text="{Binding SiteWeb, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Étape 2 : Visuel -->
                <Border Background="White" CornerRadius="10" Padding="20"
                        Visibility="{Binding EstEtape2, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <TextBlock Text="Logo et couleurs de marque" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"/>
                        <TextBlock Text="Utilisés sur les bulletins PDF, en-têtes et l'interface." FontSize="12" Foreground="#78909C" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="100" Height="100" Background="#EEEEEE" CornerRadius="8" Margin="0,0,16,0">
                                <Image Stretch="Uniform" MaxWidth="92" MaxHeight="92" Margin="4"
                                       Source="{Binding CheminLogoComplet, Converter={StaticResource PathToImageSourceConverter}}"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button Content="Choisir un logo" Command="{Binding ChoisirLogoCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,8"/>
                                <Button Content="Supprimer le logo" Command="{Binding SupprimerLogoCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Couleur principale *" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding CouleurPrincipale, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="#1E3A5F"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Couleur secondaire" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding CouleurSecondaire, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="#00A6B8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Étape 3 : Structure & paie -->
                <Border Background="White" CornerRadius="10" Padding="20"
                        Visibility="{Binding EstEtape3, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <TextBlock Text="Organisation et paramètres de paie" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"/>
                        <TextBox materialDesign:HintAssist.Hint="Nom du site / établissement *" Text="{Binding NomSite, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox materialDesign:HintAssist.Hint="Département par défaut *" Text="{Binding NomDepartement, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>
                        <TextBox materialDesign:HintAssist.Hint="Taux CDF pour 1 USD *" Text="{Binding TauxCdfParUsd, UpdateSourceTrigger=PropertyChanged}" Margin="0,14,0,0"/>
                        <TextBlock Text="Politique de paie par défaut, barème IPR et primes courantes seront créés pour cette entreprise."
                                   TextWrapping="Wrap" FontSize="12" Foreground="#78909C" Margin="0,8,0,16"/>
                        <TextBlock Text="Pointeuse ZKTeco (optionnel — à configurer plus tard)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Adresse IP terminal" Text="{Binding ZkTerminalIp, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Port" Text="{Binding ZkPortText, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Étape 4 : Administrateur -->
                <Border Background="White" CornerRadius="10" Padding="20"
                        Visibility="{Binding EstEtape4, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <TextBlock Text="Compte administrateur" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                        <Border Background="#FFF8E1" CornerRadius="8" Padding="10" Margin="0,0,0,10"
                                Visibility="{Binding DoitRemplacerMotDePasseParDefaut, Converter={StaticResource BoolVis}}">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#E65100">
                                <Run Text="Le compte par défaut admin/admin doit être remplacé. "/>
                                <Run Text="Saisissez un nouveau mot de passe dans les deux champs ci-dessous (identiques)." FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#78909C" Margin="0,0,0,14">
                            <Run Text="Ce compte servira à la connexion juste après cette configuration (étape 2/2)."/>
                            <LineBreak/>
                            <Run Text="Mot de passe : 8 caractères minimum, au moins une lettre et un chiffre — saisissez exactement le même texte dans « Mot de passe » et « Confirmer »."/>
                        </TextBlock>
                        <TextBox materialDesign:HintAssist.Hint="Identifiant de connexion (ex. prenom.nom) *" Text="{Binding AdminLogin, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox materialDesign:HintAssist.Hint="Nom complet" Text="{Binding AdminNomComplet, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>
                        <PasswordBox x:Name="PwdAdmin" materialDesign:HintAssist.Hint="Mot de passe *" Margin="0,10,0,0"
                                     PasswordChanged="PwdAdmin_PasswordChanged" LostFocus="PwdAdmin_LostFocus"/>
                        <PasswordBox x:Name="PwdAdminConfirm" materialDesign:HintAssist.Hint="Confirmer le mot de passe *" Margin="0,10,0,0"
                                     PasswordChanged="PwdAdminConfirm_PasswordChanged" LostFocus="PwdAdminConfirm_LostFocus"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Navigation -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Précédent" Command="{Binding PrecedentCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Padding="20,10"/>
            <Button Grid.Column="2" Content="Suivant" Command="{Binding SuivantCommand}"
                    Visibility="{Binding AfficherSuivant, Converter={StaticResource BoolVis}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#00838F" BorderBrush="#00838F" Padding="24,10" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Terminer la configuration"
                    Click="TerminerConfiguration_Click"
                    Visibility="{Binding AfficherTerminer, Converter={StaticResource BoolVis}}"
                    Style="{StaticResource BrandRaisedButton}" Padding="20,10"/>
        </Grid>
    </Grid>
</Window>
