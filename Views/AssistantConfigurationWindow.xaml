<Window x:Class="MelodyPaieRDC.Views.AssistantConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Configuration initiale"
        Height="620" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding Titre}" FontSize="20" FontWeight="SemiBold" Foreground="#1E3A5F"/>
            <TextBlock Text="Configurez votre entreprise avant d'utiliser les employés, la paie et le pointage. Les données d'une autre entreprise ou d'un ancien import ne seront visibles qu'après sélection du bon contexte."
                       TextWrapping="Wrap" Margin="0,8,0,0" Foreground="#546E7A" FontSize="13"/>
            <Border Background="#E3F2FD" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                <TextBlock Text="{Binding MessageEtat}" TextWrapping="Wrap" Foreground="#1565C0"/>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Étape 1 -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="1. Identité de l'entreprise" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text=" ✓" Foreground="#2E7D32" FontWeight="Bold" Margin="8,0,0,0"
                                       Visibility="{Binding IdentiteOk, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                        <TextBox materialDesign:HintAssist.Hint="Raison sociale *" Text="{Binding RaisonSociale, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>
                        <TextBox materialDesign:HintAssist.Hint="NIF" Text="{Binding Nif, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0"/>
                        <TextBox materialDesign:HintAssist.Hint="Adresse" Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0"/>
                        <Button Content="Enregistrer l'identité" Command="{Binding EnregistrerEtape1Command}"
                                Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,12,0,0" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Étape 2 -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="2. Site et département" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text=" ✓" Foreground="#2E7D32" FontWeight="Bold" Margin="8,0,0,0"
                                       Visibility="{Binding StructureOk, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                        <TextBox materialDesign:HintAssist.Hint="Nom du site / établissement *" Text="{Binding NomSite, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>
                        <TextBox materialDesign:HintAssist.Hint="Département par défaut *" Text="{Binding NomDepartement, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0"/>
                        <Button Content="Enregistrer la structure" Command="{Binding EnregistrerEtape2Command}"
                                Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,12,0,0" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Étape 3 -->
                <Border Background="White" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="3. Paie et taux de change" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text=" ✓" Foreground="#2E7D32" FontWeight="Bold" Margin="8,0,0,0"
                                       Visibility="{Binding PolitiqueOk, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                        <TextBox materialDesign:HintAssist.Hint="Taux CDF pour 1 USD *" Text="{Binding TauxCdfParUsd, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>
                        <TextBlock Text="Une politique de paie par défaut sera créée pour votre entreprise (barème, rubriques de base)."
                                   TextWrapping="Wrap" Foreground="#78909C" FontSize="12" Margin="0,8,0,0"/>
                        <Button Content="Enregistrer les paramètres paie" Command="{Binding EnregistrerEtape3Command}"
                                Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,12,0,0" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Terminer et ouvrir l'application" Command="{Binding TerminerCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1E3A5F" BorderBrush="#1E3A5F"/>
        </StackPanel>
    </Grid>
</Window>
